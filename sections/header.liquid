{%- liquid
  capture configure_buy_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_buy_url = configure_buy_url | strip
  assign header_cta_url = section.settings.cta_url | strip
  if header_cta_url == blank
    assign header_cta_url = configure_buy_url
  endif
  assign header_cta_desktop = section.settings.cta_label
  if header_cta_desktop == blank
    assign header_cta_desktop = 'header.buy_now' | t
  endif
  assign header_cta_mobile = section.settings.cta_label_mobile
  if header_cta_mobile == blank
    assign header_cta_mobile = 'header.buy' | t
  endif
  assign main_menu = section.settings.main_menu
  assign root = routes.root_url
  if cart.item_count == 1
    assign cart_label = 'accessibility.cart_item' | t: count: cart.item_count
  else
    assign cart_label = 'accessibility.cart_items' | t: count: cart.item_count
  endif
-%}

<header class="site-header" role="banner" data-theme="dark">
  <div class="site-header__inner">
    <div class="site-header__brand" data-header-zone="brand">
      <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name | escape }} home">
        {% render 'lurafi-logo', class: 'site-header__logo-img' %}
      </a>
    </div>

    <nav class="site-nav" aria-label="{{ 'accessibility.main_navigation' | t }}" data-header-zone="nav">
      {%- if main_menu != blank and main_menu.links.size > 0 -%}
        {% render 'nav-links', menu: main_menu, link_class: 'site-nav__link', close_menu: false %}
      {%- else -%}
        <a href="{{ root }}#problem" class="site-nav__link">{{ 'header.why_kevin' | t }}</a>
        <a href="{{ root }}#product" class="site-nav__link">{{ 'header.product' | t }}</a>
        <a href="{{ root }}#how-it-works" class="site-nav__link">{{ 'header.how_it_works' | t }}</a>
        <a href="{{ root }}#app" class="site-nav__link">{{ 'header.app' | t }}</a>
        <a href="{{ root }}#pricing" class="site-nav__link">{{ 'header.pricing' | t }}</a>
      {%- endif -%}
    </nav>

    <div class="site-header__utilities" data-header-zone="utilities">
      <div class="site-header__lang">
        {% render 'language-selector', form_id: 'HeaderLanguageForm', selector_id: 'HeaderLanguageSelector' %}
      </div>

      <div class="site-header__actions">
        {%- if customer -%}
          <a href="{{ routes.account_url }}" class="site-header__account-link">{{ 'header.account' | t }}</a>
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="site-header__account-link">{{ 'header.log_in' | t }}</a>
        {%- endif -%}
        <a href="{{ header_cta_url }}" class="btn-apple-primary btn-apple-primary--sm site-header__cta site-header__cta--mobile">
          {{ header_cta_mobile | escape }}
        </a>
        <button type="button" class="site-header__icon site-header__cart" aria-label="{{ cart_label | escape }}" data-cart-drawer-open>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M3.5 5h11l-1.1 8.4a1.5 1.5 0 0 1-1.5 1.3H6.1a1.5 1.5 0 0 1-1.5-1.3L3.5 5z"/>
            <path d="M6.5 5V3.75a2.5 2.5 0 0 1 5 0V5"/>
          </svg>
          <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </button>
        <button type="button" class="site-header__menu-btn" aria-label="{{ 'accessibility.open_menu' | t }}" aria-expanded="false" aria-controls="MobileNavPanel" data-menu-open>
          <span class="site-header__menu-icon" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        </button>
        <a href="{{ header_cta_url }}" class="btn-apple-primary btn-apple-primary--sm site-header__cta site-header__cta--desktop">
          {{ header_cta_desktop | escape }}
        </a>
      </div>
    </div>
  </div>
</header>

<div class="mobile-nav" id="MobileNav" data-open="false" aria-hidden="true" hidden>
  <div class="mobile-nav__backdrop" data-menu-close tabindex="-1" aria-hidden="true"></div>
  <div
    class="mobile-nav__panel"
    id="MobileNavPanel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="MobileNavBrand"
    tabindex="-1"
  >
    <div class="mobile-nav__header">
      <a href="{{ routes.root_url }}" id="MobileNavBrand" class="mobile-nav__brand" data-menu-close aria-label="{{ shop.name | escape }} home">
        {% render 'lurafi-logo', class: 'mobile-nav__brand-img' %}
      </a>
      <button type="button" class="mobile-nav__close" data-menu-close aria-label="{{ 'accessibility.close_menu' | t }}">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="mobile-nav__lang">
      <p class="mobile-nav__group-label">{{ 'language.label' | t }}</p>
      {% render 'language-selector', form_id: 'MobileNavLanguageForm', selector_id: 'MobileNavLanguageSelector' %}
    </div>
    <nav class="mobile-nav__links" aria-label="{{ 'accessibility.mobile_navigation' | t }}">
      <p class="mobile-nav__group-label">{{ 'header.explore' | t }}</p>
      {%- if main_menu != blank and main_menu.links.size > 0 -%}
        {% render 'nav-links', menu: main_menu, link_class: 'mobile-nav__link', close_menu: true %}
      {%- else -%}
        <a href="{{ root }}#problem" class="mobile-nav__link" data-menu-close>{{ 'header.why_kevin' | t }}</a>
        <a href="{{ root }}#product" class="mobile-nav__link" data-menu-close>{{ 'header.product' | t }}</a>
        <a href="{{ root }}#how-it-works" class="mobile-nav__link" data-menu-close>{{ 'header.how_it_works' | t }}</a>
        <a href="{{ root }}#app" class="mobile-nav__link" data-menu-close>{{ 'header.app' | t }}</a>
      {%- endif -%}
      <p class="mobile-nav__group-label">{{ 'header.buy_group' | t }}</p>
      <a href="{{ root }}#pricing" class="mobile-nav__link" data-menu-close>{{ 'header.pricing' | t }}</a>
      <button type="button" class="mobile-nav__link mobile-nav__cart-link" aria-label="{{ cart_label | escape }}" data-cart-drawer-open data-menu-close>{{ 'header.cart' | t }}{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</button>
      <p class="mobile-nav__group-label">{{ 'header.support' | t }}</p>
      <a href="{{ root }}#app" class="mobile-nav__link" data-menu-close>{{ 'header.setup_and_app' | t }}</a>
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="mobile-nav__link" data-menu-close>{{ 'header.account' | t }}</a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="mobile-nav__link" data-menu-close>{{ 'header.log_in' | t }}</a>
      {%- endif -%}
    </nav>
    <div class="mobile-nav__footer">
      <a href="{{ header_cta_url }}" class="btn-apple-primary btn-block mobile-nav__buy" data-menu-close>{{ header_cta_desktop | escape }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main navigation menu",
      "info": "Online Store → Navigation. Leave empty to use default homepage anchor links."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Desktop CTA label",
      "default": "Buy Now"
    },
    {
      "type": "text",
      "id": "cta_label_mobile",
      "label": "Mobile header CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Header CTA URL",
      "info": "Leave blank to use the Configure (buy) page."
    }
  ]
}
{% endschema %}

<div class="page-width form-stack">
  <section id="CustomerLogin">
    <h1>{{ 'customers.login.title' | t }}</h1>

    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label for="CustomerEmail">{{ 'customers.login.email' | t }}</label>
      <input
        id="CustomerEmail"
        type="email"
        name="customer[email]"
        autocomplete="email"
        autocorrect="off"
        autocapitalize="off"
        required
      >

      <label for="CustomerPassword">{{ 'customers.login.password' | t }}</label>
      <input
        id="CustomerPassword"
        type="password"
        name="customer[password]"
        autocomplete="current-password"
        required
      >

      <button type="submit" class="button">{{ 'customers.login.submit' | t }}</button>

      <p>
        <a href="#RecoverPassword">{{ 'customers.login.forgot_password' | t }}</a>
      </p>
      <p>
        {{ 'customers.login.new_customer' | t }}
        <a href="{{ routes.account_register_url }}">{{ 'customers.login.create_account' | t }}</a>
      </p>
    {%- endform -%}
  </section>

  <section id="RecoverPassword" class="customer-login__recover">
    <h2>{{ 'customers.login.recover_title' | t }}</h2>
    <p>{{ 'customers.login.recover_lede' | t }}</p>

    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <p>{{ 'customers.login.recover_success' | t }}</p>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form__errors" role="alert">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label for="RecoverEmail">{{ 'customers.login.email' | t }}</label>
      <input
        id="RecoverEmail"
        type="email"
        name="email"
        autocomplete="email"
        required
      >

      <button type="submit" class="button">{{ 'customers.login.recover_submit' | t }}</button>
    {%- endform -%}
  </section>
</div>

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}

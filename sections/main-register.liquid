<div class="page-width form-stack">
  <h1>{{ 'customers.register.title' | t }}</h1>

  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <div class="form__errors" role="alert">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <label for="FirstName">{{ 'customers.register.first_name' | t }}</label>
    <input
      id="FirstName"
      type="text"
      name="customer[first_name]"
      autocomplete="given-name"
      value="{% if form.first_name %}{{ form.first_name }}{% endif %}"
    >

    <label for="LastName">{{ 'customers.register.last_name' | t }}</label>
    <input
      id="LastName"
      type="text"
      name="customer[last_name]"
      autocomplete="family-name"
      value="{% if form.last_name %}{{ form.last_name }}{% endif %}"
    >

    <label for="Email">{{ 'customers.register.email' | t }}</label>
    <input
      id="Email"
      type="email"
      name="customer[email]"
      autocomplete="email"
      autocorrect="off"
      autocapitalize="off"
      value="{% if form.email %}{{ form.email }}{% endif %}"
      required
    >

    <label for="CreatePassword">{{ 'customers.register.password' | t }}</label>
    <input
      id="CreatePassword"
      type="password"
      name="customer[password]"
      autocomplete="new-password"
      required
    >

    <button type="submit" class="button">{{ 'customers.register.submit' | t }}</button>

    <p>
      {{ 'customers.register.has_account' | t }}
      <a href="{{ routes.account_login_url }}">{{ 'customers.register.log_in' | t }}</a>
    </p>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Register",
  "settings": []
}
{% endschema %}

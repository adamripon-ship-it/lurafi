{%- comment -%}
  Video showcase — sits directly under the Hero. Merchant selects a video via
  Shopify's native "video" setting (Admin-hosted, adaptively streamed — keeps
  large media out of the theme repo). Real content video with sound, so it
  uses standard controls rather than the ambient/autoplay loop pattern. Renders
  nothing on the live storefront until a video is chosen; shows a hint in the
  theme editor instead.
{%- endcomment -%}
{%- liquid
  assign overline = section.settings.overline
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign caption = section.settings.caption
-%}

{%- if section.settings.video != blank -%}
  <section class="section-apple lp-video">
    <div class="apple-container">
      {% render 'section-intro',
        overline: overline,
        heading: heading,
        subheading: subheading
      %}

      <div class="lp-video__frame">
        {{ section.settings.video | video_tag: image_size: '1600x', controls: true, preload: 'metadata', class: 'lp-video__player' }}

        {%- if caption != blank -%}
          <p class="lp-video__caption body-reduced text-muted">{{ caption | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- elsif request.design_mode -%}
  <section class="section-apple lp-video">
    <div class="apple-container">
      <p class="body-standard text-muted" style="text-align: center;">
        Video showcase: pick a video in the section settings (right panel) to show it here.
      </p>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Video showcase",
  "settings": [
    {
      "type": "paragraph",
      "content": "Heading fields are optional — leave blank to show only the video."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Upload or select a video here — Shopify hosts it and streams adaptive resolutions. The section is hidden on the live storefront until a video is chosen."
    },
    { "type": "text", "id": "caption", "label": "Caption (optional)" }
  ],
  "presets": [
    {
      "name": "Video showcase"
    }
  ]
}
{% endschema %}

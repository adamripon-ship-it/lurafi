{%- comment -%}
  Video showcase — sits directly under the Hero. Native "video" setting lets a
  merchant swap in a Shopify-hosted video (adaptive streaming); left blank, the
  bundled default video ships instead. Real content video with sound, so it
  uses standard controls rather than the ambient/autoplay loop pattern.
{%- endcomment -%}
{%- liquid
  assign overline = section.settings.overline
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign caption = section.settings.caption
-%}

<section class="section-apple lp-video">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading
    %}

    <div class="lp-video__frame">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: image_size: '1600x', controls: true, preload: 'metadata', class: 'lp-video__player' }}
      {%- else -%}
        <video
          class="lp-video__player"
          controls
          playsinline
          preload="metadata"
          {%- if section.settings.poster != blank %}
          poster="{{ section.settings.poster | image_url: width: 1600 }}"
          {%- endif %}
        >
          <source src="{{ 'kevin-video-showcase.mp4' | asset_url }}" type="video/mp4">
        </video>
      {%- endif -%}

      {%- if caption != blank -%}
        <p class="lp-video__caption body-reduced text-muted">{{ caption | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video showcase",
  "settings": [
    {
      "type": "paragraph",
      "content": "Heading fields are optional — leave blank to show only the video."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Optional. Upload/select a video here to have Shopify host it with adaptive streaming. Leave blank to use the bundled default video."
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster image",
      "info": "Only used with the bundled default video (the Video field above generates its own poster)."
    },
    { "type": "text", "id": "caption", "label": "Caption (optional)" }
  ],
  "presets": [
    {
      "name": "Video showcase"
    }
  ]
}
{% endschema %}

{% comment %} Plain-text page for AI crawlers (Page handle "llms", template page.llms) {% endcomment %}
{%- liquid
  capture configure_buy_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_buy_url = configure_buy_url | strip
  assign llms_short_url = 'llms.txt' | asset_url
  assign llms_full_url = 'llms-full.txt' | asset_url
  assign ai_sitemap_url = 'sitemap-ai.xml' | asset_url
  assign locale_root = request.locale.iso_code | split: '-' | first | downcase
  if locale_root != 'en'
    assign llms_short_local = 'llms.' | append: locale_root | append: '.txt' | asset_url
    assign llms_full_local = 'llms-full.' | append: locale_root | append: '.txt' | asset_url
  endif
-%}
# {{ shop.name }}

> {{ 'llms_page.oneliner' | t }}

## {{ 'llms_page.ai_discovery' | t }}

- **{{ 'sitemap.short_llm' | t }} (EN):** https:{{ llms_short_url }}
- **{{ 'sitemap.full_llm' | t }} (EN):** https:{{ llms_full_url }}
{%- if llms_short_local != blank -%}
- **{{ 'sitemap.short_llm' | t }} ({{ locale_root | upcase }}):** https:{{ llms_short_local }}
- **{{ 'sitemap.full_llm' | t }} ({{ locale_root | upcase }}):** https:{{ llms_full_local }}
{%- endif -%}
- **{{ 'sitemap.ai_sitemap' | t }}:** https:{{ ai_sitemap_url }}
- **{{ 'sitemap.shopify_sitemap' | t }}:** {{ shop.url }}/sitemap.xml
- **{{ 'sitemap.human_sitemap' | t }}:** {{ shop.url }}/pages/sitemap


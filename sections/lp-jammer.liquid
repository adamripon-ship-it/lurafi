{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.jammer.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.jammer.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.jammer.subheading' | t
  endif
  # Shopify-stored copy can arrive pre-encoded; decode common entities so the
  # | escape at render cannot double-encode them into visible &#39; / &amp;.
  assign col_1_title = section.settings.col_1_title
  if col_1_title == blank
    assign col_1_title = 'home.jammer.col_1_title' | t
  endif
  assign col_1_title = col_1_title | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign col_1_body = section.settings.col_1_body
  if col_1_body == blank
    assign col_1_body = 'home.jammer.col_1_body' | t
  endif
  assign col_1_body = col_1_body | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign col_1_status = section.settings.col_1_status
  if col_1_status == blank
    assign col_1_status = 'home.jammer.col_1_status' | t
  endif
  assign col_1_status = col_1_status | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign col_2_title = section.settings.col_2_title
  if col_2_title == blank
    assign col_2_title = 'home.jammer.col_2_title' | t
  endif
  assign col_2_title = col_2_title | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign col_2_body = section.settings.col_2_body
  if col_2_body == blank
    assign col_2_body = 'home.jammer.col_2_body' | t
  endif
  assign col_2_body = col_2_body | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign col_2_status = section.settings.col_2_status
  if col_2_status == blank
    assign col_2_status = 'home.jammer.col_2_status' | t
  endif
  assign col_2_status = col_2_status | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
-%}

<section class="section-apple nf-jammer">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'dark'
    %}

    <div class="tile-grid-2">
      <div class="tile tile--dark nf-jammer__col nf-jammer__col--dead">
        <div class="nf-signal" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <h3 class="nf-jammer__title text-white">{{ col_1_title | escape }}</h3>
        <p class="body-standard text-muted-dark">{{ col_1_body | escape }}</p>
        <p class="nf-jammer__status nf-jammer__status--dead">{{ col_1_status | escape }}</p>
      </div>

      <div class="tile tile--dark nf-jammer__col nf-jammer__col--alive">
        <div class="nf-soundbars nf-soundbars--inline" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <h3 class="nf-jammer__title text-white">{{ col_2_title | escape }}</h3>
        <p class="body-standard text-muted-dark">{{ col_2_body | escape }}</p>
        <p class="nf-jammer__status nf-jammer__status--alive">{{ col_2_status | escape }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Jammer story",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "col_1_title", "label": "Column 1 title (camera)" },
    { "type": "textarea", "id": "col_1_body", "label": "Column 1 body" },
    { "type": "text", "id": "col_1_status", "label": "Column 1 status label" },
    { "type": "text", "id": "col_2_title", "label": "Column 2 title (Kevin)" },
    { "type": "textarea", "id": "col_2_body", "label": "Column 2 body" },
    { "type": "text", "id": "col_2_status", "label": "Column 2 status label" }
  ],
  "presets": [{ "name": "Jammer story" }]
}
{% endschema %}

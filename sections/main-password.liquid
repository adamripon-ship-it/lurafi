<div class="page-width password">
  <header class="password__header">
    <h1>{{ shop.name }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </header>

  <section class="password__login">
    <h2>Enter store using password</h2>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <div class="form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label for="Password">Password</label>
      <input id="Password" type="password" name="password" autocomplete="current-password" required>

      <button type="submit">Enter</button>
    {%- endform -%}
  </section>

  {%- if section.settings.show_newsletter -%}
    <section class="password__newsletter">
      <h2>{{ section.settings.newsletter_heading }}</h2>

      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <label for="NewsletterEmail">Email</label>
        <input
          id="NewsletterEmail"
          type="email"
          name="contact[email]"
          autocomplete="email"
          required
        >

        <button type="submit" name="commit">Notify me</button>

        {%- if form.posted_successfully? -%}
          <p>Thanks — we&rsquo;ll be in touch.</p>
        {%- endif -%}
      {%- endform -%}
    </section>
  {%- endif -%}

  <footer class="password__footer">
    <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</small>
  </footer>
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Opening soon"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "default": true,
      "label": "Show newsletter signup"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Be the first to know when we launch"
    }
  ]
}
{% endschema %}

<section class="section-apple bg-gray">
  <div class="apple-container">
    <h2 class="headline-section text-center" style="margin-bottom:56px">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'home.proof.heading' | t }}{%- endif -%}</h2>
    <div class="tile-grid-3">
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{%- if section.settings.quote_1 != blank -%}{{ section.settings.quote_1 }}{%- else -%}{{ 'home.proof.quote_1' | t }}{%- endif -%}</p><p style="font-size:14px;font-weight:600">{%- if section.settings.author_1_name != blank -%}{{ section.settings.author_1_name }}{%- else -%}{{ 'home.proof.author_1_name' | t }}{%- endif -%}</p><p class="body-reduced text-muted">{%- if section.settings.author_1_location != blank -%}{{ section.settings.author_1_location }}{%- else -%}{{ 'home.proof.author_1_location' | t }}{%- endif -%}</p></div>
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{%- if section.settings.quote_2 != blank -%}{{ section.settings.quote_2 }}{%- else -%}{{ 'home.proof.quote_2' | t }}{%- endif -%}</p><p style="font-size:14px;font-weight:600">{%- if section.settings.author_2_name != blank -%}{{ section.settings.author_2_name }}{%- else -%}{{ 'home.proof.author_2_name' | t }}{%- endif -%}</p><p class="body-reduced text-muted">{%- if section.settings.author_2_location != blank -%}{{ section.settings.author_2_location }}{%- else -%}{{ 'home.proof.author_2_location' | t }}{%- endif -%}</p></div>
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{%- if section.settings.quote_3 != blank -%}{{ section.settings.quote_3 }}{%- else -%}{{ 'home.proof.quote_3' | t }}{%- endif -%}</p><p style="font-size:14px;font-weight:600">{%- if section.settings.author_3_name != blank -%}{{ section.settings.author_3_name }}{%- else -%}{{ 'home.proof.author_3_name' | t }}{%- endif -%}</p><p class="body-reduced text-muted">{%- if section.settings.author_3_location != blank -%}{{ section.settings.author_3_location }}{%- else -%}{{ 'home.proof.author_3_location' | t }}{%- endif -%}</p></div>
    </div>
    <div class="proof-summary-card">
      <p class="proof-summary-card__eyebrow">Why it converts hesitation into confidence</p>
      <p>Kevin is simple to place, private by design, and most convincing from the exact perspective that matters: outside the home.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "quote_1", "label": "Quote 1" },
    { "type": "text", "id": "author_1_name", "label": "Author 1 name" },
    { "type": "text", "id": "author_1_location", "label": "Author 1 location" },
    { "type": "textarea", "id": "quote_2", "label": "Quote 2" },
    { "type": "text", "id": "author_2_name", "label": "Author 2 name" },
    { "type": "text", "id": "author_2_location", "label": "Author 2 location" },
    { "type": "textarea", "id": "quote_3", "label": "Quote 3" },
    { "type": "text", "id": "author_3_name", "label": "Author 3 name" },
    { "type": "text", "id": "author_3_location", "label": "Author 3 location" }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}

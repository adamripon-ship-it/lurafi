{%- liquid
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.proof.heading' | t
  endif
-%}

<section id="proof" class="section-apple bg-gray">
  <div class="apple-container">
    <h2 class="headline-section text-center section-intro__heading proof-section__heading">{{ heading | escape }}</h2>

    {%- liquid
      comment
        CMS v2: testimonial metaobject entries take over when present (Admin →
        Content → Metaobjects → Testimonial; fields: quote, author, location).
        Falls back to blocks / section settings / locale copy below.
      endcomment
      assign testimonial_entries = shop.metaobjects.testimonial.values
    -%}
    <div class="proof-featured">
      {%- if testimonial_entries and testimonial_entries.size > 0 -%}
        {%- for entry in testimonial_entries -%}
          {%- liquid
            assign card_class = 'proof-quote-card tile tile--white'
            if forloop.first
              assign card_class = card_class | append: ' proof-quote-card--featured'
            endif
          -%}
          {% render 'proof-quote-card',
            quote: entry.quote.value,
            author_name: entry.author.value,
            author_location: entry.location.value,
            card_class: card_class
          %}
        {%- endfor -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- assign featured_rendered = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'quote' -%}
            {%- liquid
              assign quote_text = block.settings.text
              if quote_text == blank
                assign quote_text = 'home.proof.quote_1' | t
              endif
              assign quote_author = block.settings.author_name
              if quote_author == blank
                assign quote_author = 'home.proof.author_1_name' | t
              endif
              assign quote_location = block.settings.author_location
              if quote_location == blank
                assign quote_location = 'home.proof.author_1_location' | t
              endif
              assign card_class = 'proof-quote-card tile tile--white'
              unless featured_rendered
                assign card_class = card_class | append: ' proof-quote-card--featured'
                assign featured_rendered = true
              endunless
            -%}
            {% render 'proof-quote-card',
              quote: quote_text,
              author_name: quote_author,
              author_location: quote_location,
              card_class: card_class,
              block_attributes: block.shopify_attributes
            %}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- liquid
          assign quote_1 = section.settings.quote_1
          if quote_1 == blank
            assign quote_1 = 'home.proof.quote_1' | t
          endif
          assign author_1_name = section.settings.author_1_name
          if author_1_name == blank
            assign author_1_name = 'home.proof.author_1_name' | t
          endif
          assign author_1_location = section.settings.author_1_location
          if author_1_location == blank
            assign author_1_location = 'home.proof.author_1_location' | t
          endif

          assign quote_2 = section.settings.quote_2
          if quote_2 == blank
            assign quote_2 = 'home.proof.quote_2' | t
          endif
          assign author_2_name = section.settings.author_2_name
          if author_2_name == blank
            assign author_2_name = 'home.proof.author_2_name' | t
          endif
          assign author_2_location = section.settings.author_2_location
          if author_2_location == blank
            assign author_2_location = 'home.proof.author_2_location' | t
          endif

          assign quote_3 = section.settings.quote_3
          if quote_3 == blank
            assign quote_3 = 'home.proof.quote_3' | t
          endif
          assign author_3_name = section.settings.author_3_name
          if author_3_name == blank
            assign author_3_name = 'home.proof.author_3_name' | t
          endif
          assign author_3_location = section.settings.author_3_location
          if author_3_location == blank
            assign author_3_location = 'home.proof.author_3_location' | t
          endif
        -%}
        {% render 'proof-quote-card', quote: quote_1, author_name: author_1_name, author_location: author_1_location, card_class: 'proof-quote-card tile tile--white proof-quote-card--featured' %}
        {% render 'proof-quote-card', quote: quote_2, author_name: author_2_name, author_location: author_2_location, card_class: 'proof-quote-card tile tile--white' %}
        {% render 'proof-quote-card', quote: quote_3, author_name: author_3_name, author_location: author_3_location, card_class: 'proof-quote-card tile tile--white' %}
      {%- endif -%}
    </div>

    <div class="proof-summary-card">
      <p class="proof-summary-card__eyebrow">
        {%- if section.settings.summary_eyebrow != blank -%}
          {{ section.settings.summary_eyebrow }}
        {%- else -%}
          {{ 'home.proof.summary_eyebrow' | t }}
        {%- endif -%}
      </p>
      <p>
        {%- if section.settings.summary_body != blank -%}
          {{ section.settings.summary_body }}
        {%- else -%}
          {{ 'home.proof.summary_body' | t }}
        {%- endif -%}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "header", "content": "Section" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "header", "content": "Summary (below quotes)" },
    { "type": "text", "id": "summary_eyebrow", "label": "Summary eyebrow" },
    { "type": "textarea", "id": "summary_body", "label": "Summary body" },
    { "type": "header", "content": "Legacy quote slots", "info": "Used when no quote blocks are added below." },
    { "type": "textarea", "id": "quote_1", "label": "Quote 1" },
    { "type": "text", "id": "author_1_name", "label": "Author 1 name" },
    { "type": "text", "id": "author_1_location", "label": "Author 1 location" },
    { "type": "textarea", "id": "quote_2", "label": "Quote 2" },
    { "type": "text", "id": "author_2_name", "label": "Author 2 name" },
    { "type": "text", "id": "author_2_location", "label": "Author 2 location" },
    { "type": "textarea", "id": "quote_3", "label": "Quote 3" },
    { "type": "text", "id": "author_3_name", "label": "Author 3 name" },
    { "type": "text", "id": "author_3_location", "label": "Author 3 location" }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Quote" },
        { "type": "text", "id": "author_name", "label": "Author name" },
        { "type": "text", "id": "author_location", "label": "Author location" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}

<section id="proof" class="section-apple bg-gray">
  <div class="apple-container">
    <h2 class="headline-section text-center proof-section__heading">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ 'home.proof.heading' | t }}
      {%- endif -%}
    </h2>
    <div class="tile-grid-3 proof-quote-grid">
      {%- liquid
        assign quote_1 = section.settings.quote_1
        if quote_1 == blank
          assign quote_1 = 'home.proof.quote_1' | t
        endif
        assign author_1_name = section.settings.author_1_name
        if author_1_name == blank
          assign author_1_name = 'home.proof.author_1_name' | t
        endif
        assign author_1_location = section.settings.author_1_location
        if author_1_location == blank
          assign author_1_location = 'home.proof.author_1_location' | t
        endif

        assign quote_2 = section.settings.quote_2
        if quote_2 == blank
          assign quote_2 = 'home.proof.quote_2' | t
        endif
        assign author_2_name = section.settings.author_2_name
        if author_2_name == blank
          assign author_2_name = 'home.proof.author_2_name' | t
        endif
        assign author_2_location = section.settings.author_2_location
        if author_2_location == blank
          assign author_2_location = 'home.proof.author_2_location' | t
        endif

        assign quote_3 = section.settings.quote_3
        if quote_3 == blank
          assign quote_3 = 'home.proof.quote_3' | t
        endif
        assign author_3_name = section.settings.author_3_name
        if author_3_name == blank
          assign author_3_name = 'home.proof.author_3_name' | t
        endif
        assign author_3_location = section.settings.author_3_location
        if author_3_location == blank
          assign author_3_location = 'home.proof.author_3_location' | t
        endif
      -%}
      {% render 'proof-quote-card', quote: quote_1, author_name: author_1_name, author_location: author_1_location %}
      {% render 'proof-quote-card', quote: quote_2, author_name: author_2_name, author_location: author_2_location %}
      {% render 'proof-quote-card', quote: quote_3, author_name: author_3_name, author_location: author_3_location %}
    </div>
    <div class="proof-summary-card">
      <p class="proof-summary-card__eyebrow">
        {%- if section.settings.summary_eyebrow != blank -%}
          {{ section.settings.summary_eyebrow }}
        {%- else -%}
          {{ 'home.proof.summary_eyebrow' | t }}
        {%- endif -%}
      </p>
      <p>
        {%- if section.settings.summary_body != blank -%}
          {{ section.settings.summary_body }}
        {%- else -%}
          {{ 'home.proof.summary_body' | t }}
        {%- endif -%}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "quote_1", "label": "Quote 1" },
    { "type": "text", "id": "author_1_name", "label": "Author 1 name" },
    { "type": "text", "id": "author_1_location", "label": "Author 1 location" },
    { "type": "textarea", "id": "quote_2", "label": "Quote 2" },
    { "type": "text", "id": "author_2_name", "label": "Author 2 name" },
    { "type": "text", "id": "author_2_location", "label": "Author 2 location" },
    { "type": "textarea", "id": "quote_3", "label": "Quote 3" },
    { "type": "text", "id": "author_3_name", "label": "Author 3 name" },
    { "type": "text", "id": "author_3_location", "label": "Author 3 location" },
    { "type": "text", "id": "summary_eyebrow", "label": "Summary eyebrow" },
    { "type": "textarea", "id": "summary_body", "label": "Summary body" }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}

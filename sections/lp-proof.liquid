<section class="section-apple bg-gray">
  <div class="apple-container">
    <h2 class="headline-section text-center" style="margin-bottom:56px">{{ section.settings.heading | default: 'home.proof.heading' | t }}</h2>
    <div class="tile-grid-3">
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{{ section.settings.quote_1 | default: 'home.proof.quote_1' | t }}</p><p style="font-size:14px;font-weight:600">{{ section.settings.author_1_name | default: 'home.proof.author_1_name' | t }}</p><p class="body-reduced text-muted">{{ section.settings.author_1_location | default: 'home.proof.author_1_location' | t }}</p></div>
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{{ section.settings.quote_2 | default: 'home.proof.quote_2' | t }}</p><p style="font-size:14px;font-weight:600">{{ section.settings.author_2_name | default: 'home.proof.author_2_name' | t }}</p><p class="body-reduced text-muted">{{ section.settings.author_2_location | default: 'home.proof.author_2_location' | t }}</p></div>
      <div class="tile tile--white"><div class="stars">★★★★★</div><p class="body-standard" style="margin-bottom:20px">{{ section.settings.quote_3 | default: 'home.proof.quote_3' | t }}</p><p style="font-size:14px;font-weight:600">{{ section.settings.author_3_name | default: 'home.proof.author_3_name' | t }}</p><p class="body-reduced text-muted">{{ section.settings.author_3_location | default: 'home.proof.author_3_location' | t }}</p></div>
    </div>
    <div class="proof-summary-card">
      <p class="proof-summary-card__eyebrow">Why it converts hesitation into confidence</p>
      <p>Kevin is simple to place, private by design, and most convincing from the exact perspective that matters: outside the home.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real enough from the outside." },
    { "type": "textarea", "id": "quote_1", "label": "Quote 1", "default": "\"From the pavement it looks and sounds like someone is home. That is exactly what I wanted.\"" },
    { "type": "text", "id": "author_1_name", "label": "Author 1 name", "default": "Sarah M." },
    { "type": "text", "id": "author_1_location", "label": "Author 1 location", "default": "Zurich, Switzerland" },
    { "type": "textarea", "id": "quote_2", "label": "Quote 2", "default": "\"A colleague was sure I was in and rang the bell. Kevin fooled everyone—including me.\"" },
    { "type": "text", "id": "author_2_name", "label": "Author 2 name", "default": "Marc D." },
    { "type": "text", "id": "author_2_location", "label": "Author 2 location", "default": "Lyon, France" },
    { "type": "textarea", "id": "quote_3", "label": "Quote 3", "default": "\"From the stairwell you would swear someone is inside. Shadows and sound—incredibly lifelike.\"" },
    { "type": "text", "id": "author_3_name", "label": "Author 3 name", "default": "Thomas K." },
    { "type": "text", "id": "author_3_location", "label": "Author 3 location", "default": "Munich, Germany" }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}

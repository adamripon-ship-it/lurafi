{%- liquid
  assign section_image = section.settings.image
  assign section_image_fallback = 'lurafi-product-split-usecases.jpg' | asset_url
  assign section_image_alt = section.settings.image_alt
  if section_image_alt == blank
    assign section_image_alt = 'home.solution.image_alt' | t
  endif
-%}

<section id="how-it-works" class="section-apple bg-black">
  <div class="apple-container">
    <p class="overline-blue-dark">{%- if section.settings.overline != blank -%}{{ section.settings.overline }}{%- else -%}{{ 'home.solution.overline' | t }}{%- endif -%}</p>
    <h2 class="headline-section text-white text-center" style="margin-bottom:16px">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'home.solution.heading' | t }}{%- endif -%}</h2>
    <p class="body-elevated text-muted-dark text-center" style="max-width:600px;margin:0 auto 56px">{%- if section.settings.subheading != blank -%}{{ section.settings.subheading }}{%- else -%}{{ 'home.solution.subheading' | t }}{%- endif -%}</p>

    <div class="section-image section-image--split-product">
      {%- if section_image -%}
        <img
          src="{{ section_image | image_url: width: 1200 }}"
          srcset="
            {{ section_image | image_url: width: 640 }} 640w,
            {{ section_image | image_url: width: 980 }} 980w,
            {{ section_image | image_url: width: 1200 }} 1200w
          "
          sizes="(min-width: 768px) 980px, 100vw"
          alt="{{ section_image.alt | default: section_image_alt | escape }}"
          loading="lazy"
          decoding="async"
          width="{{ section_image.width | default: 1024 }}"
          height="{{ section_image.height | default: 555 }}"
        >
      {%- else -%}
        <img
          src="{{ section_image_fallback }}"
          alt="{{ section_image_alt | escape }}"
          loading="lazy"
          decoding="async"
          width="1024"
          height="555"
        >
      {%- endif -%}
    </div>

    <div class="tile-grid-3">
      <div class="text-center">
        <div class="pillar-icon">☀</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.pillar_1_title != blank -%}{{ section.settings.pillar_1_title }}{%- else -%}{{ 'home.solution.pillar_1_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.pillar_1_body != blank -%}{{ section.settings.pillar_1_body }}{%- else -%}{{ 'home.solution.pillar_1_body' | t }}{%- endif -%}</p>
      </div>
      <div class="text-center">
        <div class="pillar-icon">◐</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.pillar_2_title != blank -%}{{ section.settings.pillar_2_title }}{%- else -%}{{ 'home.solution.pillar_2_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.pillar_2_body != blank -%}{{ section.settings.pillar_2_body }}{%- else -%}{{ 'home.solution.pillar_2_body' | t }}{%- endif -%}</p>
      </div>
      <div class="text-center">
        <div class="pillar-icon">♪</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.pillar_3_title != blank -%}{{ section.settings.pillar_3_title }}{%- else -%}{{ 'home.solution.pillar_3_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.pillar_3_body != blank -%}{{ section.settings.pillar_3_body }}{%- else -%}{{ 'home.solution.pillar_3_body' | t }}{%- endif -%}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Solution pillars",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Section image"
    },
    { "type": "image_picker", "id": "image", "label": "Split product / use-case image" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    { "type": "text", "id": "pillar_1_title", "label": "Pillar 1 title" },
    {
      "type": "textarea",
      "id": "pillar_1_body",
      "label": "Pillar 1 body"
    },
    { "type": "text", "id": "pillar_2_title", "label": "Pillar 2 title" },
    {
      "type": "textarea",
      "id": "pillar_2_body",
      "label": "Pillar 2 body"
    },
    { "type": "text", "id": "pillar_3_title", "label": "Pillar 3 title" },
    {
      "type": "textarea",
      "id": "pillar_3_body",
      "label": "Pillar 3 body"
    }
  ],
  "presets": [{ "name": "Solution pillars" }]
}
{% endschema %}

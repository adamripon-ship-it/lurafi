{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.solution.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.solution.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.solution.subheading' | t
  endif

  assign outside_image = section.settings.outside_image
  assign outside_fallback = 'kevin-hero-shadow-widow-89.webp' | asset_url
  assign outside_alt = section.settings.outside_image_alt
  if outside_alt == blank
    assign outside_alt = 'home.solution.outside_image_alt' | t
  endif
  assign outside_caption = section.settings.outside_caption
  if outside_caption == blank
    assign outside_caption = 'home.solution.outside_caption' | t
  endif
-%}

<section id="how-it-works" class="section-apple bg-white">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'light'
    %}

    <div class="solution-split">
      <figure class="solution-split__visual">
        {%- if section.settings.demo_video != blank and section.settings.demo_video.sources.size > 0 -%}
          {%- liquid
            if outside_image
              assign demo_poster = outside_image | image_url: width: 960
            else
              assign demo_poster = outside_fallback
            endif
          -%}
          <video
            class="solution-split__image"
            data-ambient-video
            loop
            muted
            playsinline
            preload="metadata"
            poster="{{ demo_poster }}"
            width="960"
            height="1280"
            aria-label="{{ outside_alt | escape }}"
          >
            {%- for source in section.settings.demo_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        {%- elsif outside_image -%}
          <img
            class="solution-split__image"
            src="{{ outside_image | image_url: width: 960 }}"
            srcset="
              {{ outside_image | image_url: width: 480 }} 480w,
              {{ outside_image | image_url: width: 720 }} 720w,
              {{ outside_image | image_url: width: 960 }} 960w
            "
            sizes="(min-width: 1024px) 44vw, 92vw"
            alt="{{ outside_image.alt | default: outside_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="{{ outside_image.width | default: 960 }}"
            height="{{ outside_image.height | default: 1280 }}"
          >
        {%- else -%}
          <img
            class="solution-split__image"
            src="{{ outside_fallback }}"
            alt="{{ outside_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="960"
            height="1280"
          >
        {%- endif -%}
        {%- if outside_caption != blank -%}
          <figcaption class="solution-split__caption">{{ outside_caption | escape }}</figcaption>
        {%- endif -%}
      </figure>

      <div class="solution-split__pillars">
        <article class="solution-pillar tile tile--gray">
          <div class="pillar-icon" aria-hidden="true">☀</div>
          <h3 class="solution-pillar__title headline-tile">
            {%- if section.settings.pillar_1_title != blank -%}{{ section.settings.pillar_1_title }}{%- else -%}{{ 'home.solution.pillar_1_title' | t }}{%- endif -%}
          </h3>
          <p class="body-standard text-muted">
            {%- if section.settings.pillar_1_body != blank -%}{{ section.settings.pillar_1_body }}{%- else -%}{{ 'home.solution.pillar_1_body' | t }}{%- endif -%}
          </p>
        </article>
        <article class="solution-pillar tile tile--gray">
          <div class="pillar-icon" aria-hidden="true">◐</div>
          <h3 class="solution-pillar__title headline-tile">
            {%- if section.settings.pillar_2_title != blank -%}{{ section.settings.pillar_2_title }}{%- else -%}{{ 'home.solution.pillar_2_title' | t }}{%- endif -%}
          </h3>
          <p class="body-standard text-muted">
            {%- if section.settings.pillar_2_body != blank -%}{{ section.settings.pillar_2_body }}{%- else -%}{{ 'home.solution.pillar_2_body' | t }}{%- endif -%}
          </p>
        </article>
        <article class="solution-pillar tile tile--gray">
          <div class="pillar-icon" aria-hidden="true">♪</div>
          <h3 class="solution-pillar__title headline-tile">
            {%- if section.settings.pillar_3_title != blank -%}{{ section.settings.pillar_3_title }}{%- else -%}{{ 'home.solution.pillar_3_title' | t }}{%- endif -%}
          </h3>
          <p class="body-standard text-muted">
            {%- if section.settings.pillar_3_body != blank -%}{{ section.settings.pillar_3_body }}{%- else -%}{{ 'home.solution.pillar_3_body' | t }}{%- endif -%}
          </p>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Solution pillars",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "header",
      "content": "Outside view"
    },
    {
      "type": "image_picker",
      "id": "outside_image",
      "label": "Street / window image",
      "info": "Default: kevin-hero-shadow-widow-89.webp — warm light visible from outside."
    },
    {
      "type": "video",
      "id": "demo_video",
      "label": "Street demo video (optional)",
      "info": "8–10s muted loop of the view from the street. Shown instead of the image; the image stays as poster and is used when reduced motion or data saving is on."
    },
    { "type": "text", "id": "outside_image_alt", "label": "Outside image alt text" },
    { "type": "text", "id": "outside_caption", "label": "Outside image caption" },
    { "type": "text", "id": "pillar_1_title", "label": "Pillar 1 title" },
    { "type": "textarea", "id": "pillar_1_body", "label": "Pillar 1 body" },
    { "type": "text", "id": "pillar_2_title", "label": "Pillar 2 title" },
    { "type": "textarea", "id": "pillar_2_body", "label": "Pillar 2 body" },
    { "type": "text", "id": "pillar_3_title", "label": "Pillar 3 title" },
    { "type": "textarea", "id": "pillar_3_body", "label": "Pillar 3 body" }
  ],
  "presets": [{ "name": "Solution pillars" }]
}
{% endschema %}

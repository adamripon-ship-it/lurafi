{%- liquid
  assign section_image = section.settings.image
  assign section_image_fallback = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663143838195/XAqmtb4V6fmS5cL6eq54xv/lurafi-living-room-night-9F7io8GPfpmikRnGHgHLvy.webp'
  assign section_image_alt = section.settings.image_alt
  if section_image_alt == blank
    assign section_image_alt = 'home.solution.image_alt' | t
  endif
-%}

<section id="how-it-works" class="section-apple bg-black">
  <div class="apple-container">
    <p class="overline-blue-dark">{{ section.settings.overline | default: 'home.solution.overline' | t }}</p>
    <h2 class="headline-section text-white text-center" style="margin-bottom:16px">{{ section.settings.heading | default: 'home.solution.heading' | t }}</h2>
    <p class="body-elevated text-muted-dark text-center" style="max-width:600px;margin:0 auto 56px">{{ section.settings.subheading | default: 'home.solution.subheading' | t }}</p>

    <div class="section-image">
      {%- if section_image -%}
        <img
          src="{{ section_image | image_url: width: 1200 }}"
          alt="{{ section_image.alt | default: section_image_alt | escape }}"
          loading="lazy"
          width="{{ section_image.width | default: 980 }}"
          height="{{ section_image.height | default: 550 }}"
        >
      {%- else -%}
        <img src="{{ section_image_fallback }}" alt="{{ section_image_alt | escape }}" loading="lazy" width="980" height="550">
      {%- endif -%}
    </div>

    <div class="tile-grid-3">
      <div class="text-center">
        <div class="pillar-icon">☀</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{{ section.settings.pillar_1_title | default: 'home.solution.pillar_1_title' | t }}</h3>
        <p class="body-standard text-muted-dark">{{ section.settings.pillar_1_body | default: 'home.solution.pillar_1_body' | t }}</p>
      </div>
      <div class="text-center">
        <div class="pillar-icon">◐</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{{ section.settings.pillar_2_title | default: 'home.solution.pillar_2_title' | t }}</h3>
        <p class="body-standard text-muted-dark">{{ section.settings.pillar_2_body | default: 'home.solution.pillar_2_body' | t }}</p>
      </div>
      <div class="text-center">
        <div class="pillar-icon">♪</div>
        <h3 class="text-white" style="font-size:21px;font-weight:600;margin-bottom:8px">{{ section.settings.pillar_3_title | default: 'home.solution.pillar_3_title' | t }}</h3>
        <p class="body-standard text-muted-dark">{{ section.settings.pillar_3_body | default: 'home.solution.pillar_3_body' | t }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Solution pillars",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "The Kevin Method" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Deterrence that feels human." },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Place Kevin near a wall or ceiling it can use like a stage. From outside, coordinated light, movement, and sound make the room feel active, not automated."
    },
    {
      "type": "header",
      "content": "Section image"
    },
    { "type": "image_picker", "id": "image", "label": "Living room / simulation image" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Kevin presence simulation at night"
    },
    { "type": "text", "id": "pillar_1_title", "label": "Pillar 1 title", "default": "Warm light" },
    {
      "type": "textarea",
      "id": "pillar_1_body",
      "label": "Pillar 1 body",
      "default": "Bright, warm scenes make a room look lived-in instead of simply lit. Kevin varies the rhythm for mornings, evenings, and nights."
    },
    { "type": "text", "id": "pillar_2_title", "label": "Pillar 2 title", "default": "Moving shadows" },
    {
      "type": "textarea",
      "id": "pillar_2_body",
      "label": "Pillar 2 body",
      "default": "Projected silhouettes and shifting light suggest people moving through the space, without cameras or microphones."
    },
    { "type": "text", "id": "pillar_3_title", "label": "Pillar 3 title", "default": "Everyday sound" },
    {
      "type": "textarea",
      "id": "pillar_3_body",
      "label": "Pillar 3 body",
      "default": "Kitchen noise, TV ambience, footsteps, voices, and your own recordings help the simulation feel personal and less repetitive."
    }
  ],
  "presets": [{ "name": "Solution pillars" }]
}
{% endschema %}

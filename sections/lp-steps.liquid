{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.steps.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.steps.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.steps.subheading' | t
  endif

  assign steps_image = section.settings.image
  assign steps_image_fallback = 'kevin-hero-product-side.webp' | asset_url
  assign steps_image_alt = section.settings.image_alt
  if steps_image_alt == blank
    assign steps_image_alt = 'home.steps.image_alt' | t
  endif
-%}

<section id="product" class="section-apple bg-gray">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'light'
    %}

    <div class="steps-layout">
      <div class="steps-layout__media">
        <figure class="steps-layout__figure">
          {%- if steps_image -%}
            <img
              src="{{ steps_image | image_url: width: 800 }}"
              srcset="
                {{ steps_image | image_url: width: 400 }} 400w,
                {{ steps_image | image_url: width: 600 }} 600w,
                {{ steps_image | image_url: width: 800 }} 800w
              "
              sizes="(min-width: 1024px) 360px, 72vw"
              alt="{{ steps_image.alt | default: steps_image_alt | escape }}"
              width="{{ steps_image.width | default: 400 }}"
              height="{{ steps_image.height | default: 320 }}"
              loading="lazy"
              decoding="async"
            >
          {%- else -%}
            <img
              src="{{ steps_image_fallback }}"
              alt="{{ steps_image_alt | escape }}"
              width="400"
              height="320"
              loading="lazy"
              decoding="async"
            >
          {%- endif -%}
        </figure>
      </div>

      <ol class="steps-timeline" aria-label="{{ heading | escape }}">
        <li class="steps-timeline__item">
          <span class="steps-timeline__num" aria-hidden="true">1</span>
          <div class="steps-timeline__content tile tile--white">
            <h3 class="steps-timeline__title headline-tile">
              {%- if section.settings.step_1_title != blank -%}{{ section.settings.step_1_title }}{%- else -%}{{ 'home.steps.step_1_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted">
              {%- if section.settings.step_1_body != blank -%}{{ section.settings.step_1_body }}{%- else -%}{{ 'home.steps.step_1_body' | t }}{%- endif -%}
            </p>
          </div>
        </li>
        <li class="steps-timeline__item">
          <span class="steps-timeline__num" aria-hidden="true">2</span>
          <div class="steps-timeline__content tile tile--white">
            <h3 class="steps-timeline__title headline-tile">
              {%- if section.settings.step_2_title != blank -%}{{ section.settings.step_2_title }}{%- else -%}{{ 'home.steps.step_2_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted">
              {%- if section.settings.step_2_body != blank -%}{{ section.settings.step_2_body }}{%- else -%}{{ 'home.steps.step_2_body' | t }}{%- endif -%}
            </p>
          </div>
        </li>
        <li class="steps-timeline__item">
          <span class="steps-timeline__num" aria-hidden="true">3</span>
          <div class="steps-timeline__content tile tile--white">
            <h3 class="steps-timeline__title headline-tile">
              {%- if section.settings.step_3_title != blank -%}{{ section.settings.step_3_title }}{%- else -%}{{ 'home.steps.step_3_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted">
              {%- if section.settings.step_3_body != blank -%}{{ section.settings.step_3_body }}{%- else -%}{{ 'home.steps.step_3_body' | t }}{%- endif -%}
            </p>
          </div>
        </li>
      </ol>
    </div>

    <div class="stats-row" data-countup-duration="1100">
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_1_value != blank -%}{{ section.settings.stat_1_value }}{%- else -%}{{ 'home.steps.stat_1_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_1_label != blank -%}{{ section.settings.stat_1_label }}{%- else -%}{{ 'home.steps.stat_1_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_2_value != blank -%}{{ section.settings.stat_2_value }}{%- else -%}{{ 'home.steps.stat_2_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_2_label != blank -%}{{ section.settings.stat_2_label }}{%- else -%}{{ 'home.steps.stat_2_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_3_value != blank -%}{{ section.settings.stat_3_value }}{%- else -%}{{ 'home.steps.stat_3_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_3_label != blank -%}{{ section.settings.stat_3_label }}{%- else -%}{{ 'home.steps.stat_3_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_4_value != blank -%}{{ section.settings.stat_4_value }}{%- else -%}{{ 'home.steps.stat_4_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_4_label != blank -%}{{ section.settings.stat_4_label }}{%- else -%}{{ 'home.steps.stat_4_label' | t }}{%- endif -%}</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "step_1_title", "label": "Step 1 title" },
    { "type": "textarea", "id": "step_1_body", "label": "Step 1 body" },
    { "type": "text", "id": "step_2_title", "label": "Step 2 title" },
    { "type": "textarea", "id": "step_2_body", "label": "Step 2 body" },
    { "type": "text", "id": "step_3_title", "label": "Step 3 title" },
    { "type": "textarea", "id": "step_3_body", "label": "Step 3 body" },
    {
      "type": "header",
      "content": "Section image"
    },
    { "type": "image_picker", "id": "image", "label": "Kevin device image", "info": "Default: kevin-hero-product-side.webp" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 value" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 value" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 value" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label" },
    { "type": "text", "id": "stat_4_value", "label": "Stat 4 value" },
    { "type": "text", "id": "stat_4_label", "label": "Stat 4 label" }
  ],
  "presets": [{ "name": "How it works" }]
}
{% endschema %}

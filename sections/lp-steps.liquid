{%- liquid
  assign steps_image = section.settings.image
  assign steps_image_fallback = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663143838195/XAqmtb4V6fmS5cL6eq54xv/lurafi-device-angle-transparent-feBmUBJ5mWe9dTyXfTHnUU.webp'
  assign steps_image_alt = section.settings.image_alt
  if steps_image_alt == blank
    assign steps_image_alt = 'home.steps.image_alt' | t
  endif
-%}

<section id="product" class="section-apple bg-gray">
  <div class="apple-container">
    <p class="overline-blue">{%- if section.settings.overline != blank -%}{{ section.settings.overline }}{%- else -%}{{ 'home.steps.overline' | t }}{%- endif -%}</p>
    <h2 class="headline-section text-center" style="margin-bottom:16px">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'home.steps.heading' | t }}{%- endif -%}</h2>
    <p class="body-elevated text-muted text-center" style="max-width:580px;margin:0 auto 64px">{%- if section.settings.subheading != blank -%}{{ section.settings.subheading }}{%- else -%}{{ 'home.steps.subheading' | t }}{%- endif -%}</p>

    <div class="tile-grid-3" style="margin-bottom:56px">
      <div class="tile tile--white text-center">
        <p class="step-num" data-countup>1</p>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.step_1_title != blank -%}{{ section.settings.step_1_title }}{%- else -%}{{ 'home.steps.step_1_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.step_1_body != blank -%}{{ section.settings.step_1_body }}{%- else -%}{{ 'home.steps.step_1_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--white text-center">
        <p class="step-num" data-countup>2</p>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.step_2_title != blank -%}{{ section.settings.step_2_title }}{%- else -%}{{ 'home.steps.step_2_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.step_2_body != blank -%}{{ section.settings.step_2_body }}{%- else -%}{{ 'home.steps.step_2_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--white text-center">
        <p class="step-num" data-countup>3</p>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.step_3_title != blank -%}{{ section.settings.step_3_title }}{%- else -%}{{ 'home.steps.step_3_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.step_3_body != blank -%}{{ section.settings.step_3_body }}{%- else -%}{{ 'home.steps.step_3_body' | t }}{%- endif -%}</p>
      </div>
    </div>

    <div style="display:flex;justify-content:center;margin-bottom:40px">
      {%- if steps_image -%}
        <img
          src="{{ steps_image | image_url: width: 800 }}"
          alt="{{ steps_image.alt | default: steps_image_alt | escape }}"
          width="{{ steps_image.width | default: 400 }}"
          height="{{ steps_image.height | default: 320 }}"
          style="max-width:400px;width:100%"
          loading="lazy"
        >
      {%- else -%}
        <img src="{{ steps_image_fallback }}" alt="{{ steps_image_alt | escape }}" width="400" height="320" style="max-width:400px;width:100%" loading="lazy">
      {%- endif -%}
    </div>

    <div class="stats-row" data-countup-duration="1100">
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_1_value != blank -%}{{ section.settings.stat_1_value }}{%- else -%}{{ 'home.steps.stat_1_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_1_label != blank -%}{{ section.settings.stat_1_label }}{%- else -%}{{ 'home.steps.stat_1_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_2_value != blank -%}{{ section.settings.stat_2_value }}{%- else -%}{{ 'home.steps.stat_2_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_2_label != blank -%}{{ section.settings.stat_2_label }}{%- else -%}{{ 'home.steps.stat_2_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_3_value != blank -%}{{ section.settings.stat_3_value }}{%- else -%}{{ 'home.steps.stat_3_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_3_label != blank -%}{{ section.settings.stat_3_label }}{%- else -%}{{ 'home.steps.stat_3_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_4_value != blank -%}{{ section.settings.stat_4_value }}{%- else -%}{{ 'home.steps.stat_4_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_4_label != blank -%}{{ section.settings.stat_4_label }}{%- else -%}{{ 'home.steps.stat_4_label' | t }}{%- endif -%}</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "The Plan" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Plug in. Set routines. Leave calmly." },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "No installation, no wiring, no monthly monitoring panel. Kevin starts with a simple setup and grows more useful through schedules, geofencing, and updates."
    },
    { "type": "text", "id": "step_1_title", "label": "Step 1 title", "default": "Place Kevin" },
    {
      "type": "textarea",
      "id": "step_1_body",
      "label": "Step 1 body",
      "default": "Set it near a visible window with a wall or ceiling for shadows. Connect power and let the room become the stage."
    },
    { "type": "text", "id": "step_2_title", "label": "Step 2 title", "default": "Set your routine" },
    {
      "type": "textarea",
      "id": "step_2_body",
      "label": "Step 2 body",
      "default": "Use the app for weekly schedules, holiday mode, or geo-aware activation when you leave the area."
    },
    { "type": "text", "id": "step_3_title", "label": "Step 3 title", "default": "Stay believable" },
    {
      "type": "textarea",
      "id": "step_3_body",
      "label": "Step 3 body",
      "default": "Kevin plays varied light and sound scenarios from local storage, so your routines are not streamed from the cloud or shared with third parties."
    },
    {
      "type": "header",
      "content": "Section image"
    },
    { "type": "image_picker", "id": "image", "label": "Kevin device image" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Kevin device"
    },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 value", "default": "60s" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Setup time" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 value", "default": "1" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Wires needed" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 value", "default": "100%" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Privacy" },
    { "type": "text", "id": "stat_4_value", "label": "Stat 4 value", "default": "24/7" },
    { "type": "text", "id": "stat_4_label", "label": "Stat 4 label", "default": "Protection" }
  ],
  "presets": [{ "name": "How it works" }]
}
{% endschema %}

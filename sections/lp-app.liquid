{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.app.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.app.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.app.subheading' | t
  endif
  assign ui_status = section.settings.ui_status
  if ui_status == blank
    assign ui_status = 'home.app.ui_status' | t
  endif
-%}

<section id="app" class="section-apple lp-app bg-gray">
  <div class="lp-app__atmosphere" aria-hidden="true"></div>
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'dark',
      subhead_narrow: true
    %}

    {%- comment -%}
      Pure-CSS phone: typographic app UI, no screenshots. Rows are real,
      translatable text; the frame and toggles are decoration.
    {%- endcomment -%}
    <div class="nf-phone-wrap">
      <div class="nf-phone">
        <span class="nf-phone__notch" aria-hidden="true"></span>
        <div class="nf-phone__screen">
          <p class="nf-phone__status">{{ ui_status | escape }}</p>
          <ul class="nf-phone__rows" role="list">
            {%- for i in (1..4) -%}
              {%- liquid
                assign row_key = 'ui_row_' | append: i
                assign row_text = section.settings[row_key]
                if row_text == blank
                  assign row_locale_key = 'home.app.ui_row_' | append: i
                  assign row_text = row_locale_key | t
                endif
              -%}
              {%- if row_text != blank -%}
                <li class="nf-phone__row">
                  <span class="nf-phone__row-label">{{ row_text | escape }}</span>
                  <span class="nf-phone__toggle{% if i < 4 %} nf-phone__toggle--on{% endif %}" aria-hidden="true"></span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>

    <div class="lp-app__bento tile-grid-2">
      <div class="tile tile--dark">
        <h3 class="text-white lp-app__tile-title">{%- if section.settings.tile_1_title != blank -%}{{ section.settings.tile_1_title }}{%- else -%}{{ 'home.app.tile_1_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.tile_1_body != blank -%}{{ section.settings.tile_1_body }}{%- else -%}{{ 'home.app.tile_1_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--dark">
        <h3 class="text-white lp-app__tile-title">{%- if section.settings.tile_2_title != blank -%}{{ section.settings.tile_2_title }}{%- else -%}{{ 'home.app.tile_2_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.tile_2_body != blank -%}{{ section.settings.tile_2_body }}{%- else -%}{{ 'home.app.tile_2_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--dark">
        <h3 class="text-white lp-app__tile-title">{%- if section.settings.tile_3_title != blank -%}{{ section.settings.tile_3_title }}{%- else -%}{{ 'home.app.tile_3_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.tile_3_body != blank -%}{{ section.settings.tile_3_body }}{%- else -%}{{ 'home.app.tile_3_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--dark">
        <h3 class="text-white lp-app__tile-title">{%- if section.settings.tile_4_title != blank -%}{{ section.settings.tile_4_title }}{%- else -%}{{ 'home.app.tile_4_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted-dark">{%- if section.settings.tile_4_body != blank -%}{{ section.settings.tile_4_body }}{%- else -%}{{ 'home.app.tile_4_body' | t }}{%- endif -%}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kevin App",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "header",
      "content": "Phone UI (typographic mockup)"
    },
    { "type": "text", "id": "ui_status", "label": "Status line" },
    { "type": "text", "id": "ui_row_1", "label": "UI row 1" },
    { "type": "text", "id": "ui_row_2", "label": "UI row 2" },
    { "type": "text", "id": "ui_row_3", "label": "UI row 3" },
    { "type": "text", "id": "ui_row_4", "label": "UI row 4" },
    {
      "type": "header",
      "content": "Feature tiles"
    },
    { "type": "text", "id": "tile_1_title", "label": "Tile 1 title" },
    { "type": "textarea", "id": "tile_1_body", "label": "Tile 1 body" },
    { "type": "text", "id": "tile_2_title", "label": "Tile 2 title" },
    { "type": "textarea", "id": "tile_2_body", "label": "Tile 2 body" },
    { "type": "text", "id": "tile_3_title", "label": "Tile 3 title" },
    { "type": "textarea", "id": "tile_3_body", "label": "Tile 3 body" },
    { "type": "text", "id": "tile_4_title", "label": "Tile 4 title" },
    { "type": "textarea", "id": "tile_4_body", "label": "Tile 4 body" }
  ],
  "presets": [{ "name": "Kevin App" }]
}
{% endschema %}

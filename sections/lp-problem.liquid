<section id="problem" class="section-apple bg-white">
  <div class="apple-container">
    <p class="overline-blue">{%- if section.settings.overline != blank -%}{{ section.settings.overline }}{%- else -%}{{ 'home.problem.overline' | t }}{%- endif -%}</p>
    <h2 class="headline-section text-center" style="margin-bottom:16px">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'home.problem.heading' | t }}{%- endif -%}</h2>
    <p class="body-elevated text-muted text-center" style="max-width:600px;margin:0 auto 64px">{%- if section.settings.subheading != blank -%}{{ section.settings.subheading }}{%- else -%}{{ 'home.problem.subheading' | t }}{%- endif -%}</p>
    <div class="tile-grid-3">
      <div class="tile tile--gray text-center">
        <div class="feature-tile__media{% unless section.settings.tile_1_image %} feature-tile__media--icon{% endunless %}">
          {%- if section.settings.tile_1_image -%}
            <img src="{{ section.settings.tile_1_image | image_url: width: 640 }}" alt="" loading="lazy" decoding="async" width="640" height="480">
          {%- else -%}
            <svg class="feature-tile__icon" viewBox="0 0 48 48" fill="none" role="img" aria-hidden="true" focusable="false"><path d="M24 6a10 10 0 0 0-10 10v6.2l-3.2 5.3a1 1 0 0 0 .86 1.5h24.7a1 1 0 0 0 .86-1.5L34 22.2V16A10 10 0 0 0 24 6Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/><path d="M19.5 33a4.5 4.5 0 0 0 9 0" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
          {%- endif -%}
        </div>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.tile_1_title != blank -%}{{ section.settings.tile_1_title }}{%- else -%}{{ 'home.problem.tile_1_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.tile_1_body != blank -%}{{ section.settings.tile_1_body }}{%- else -%}{{ 'home.problem.tile_1_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--gray text-center">
        <div class="feature-tile__media{% unless section.settings.tile_2_image %} feature-tile__media--icon{% endunless %}">
          {%- if section.settings.tile_2_image -%}
            <img src="{{ section.settings.tile_2_image | image_url: width: 640 }}" alt="" loading="lazy" decoding="async" width="640" height="480">
          {%- else -%}
            <svg class="feature-tile__icon" viewBox="0 0 48 48" fill="none" role="img" aria-hidden="true" focusable="false"><rect x="7" y="16" width="23" height="14" rx="2.5" stroke="currentColor" stroke-width="2.2"/><path d="M30 20.5l9-3.5v14l-9-3.5" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/><circle cx="18.5" cy="23" r="3.4" stroke="currentColor" stroke-width="2.2"/></svg>
          {%- endif -%}
        </div>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.tile_2_title != blank -%}{{ section.settings.tile_2_title }}{%- else -%}{{ 'home.problem.tile_2_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.tile_2_body != blank -%}{{ section.settings.tile_2_body }}{%- else -%}{{ 'home.problem.tile_2_body' | t }}{%- endif -%}</p>
      </div>
      <div class="tile tile--gray text-center">
        <div class="feature-tile__media{% unless section.settings.tile_3_image %} feature-tile__media--icon{% endunless %}">
          {%- if section.settings.tile_3_image -%}
            <img src="{{ section.settings.tile_3_image | image_url: width: 640 }}" alt="" loading="lazy" decoding="async" width="640" height="480">
          {%- else -%}
            <svg class="feature-tile__icon" viewBox="0 0 48 48" fill="none" role="img" aria-hidden="true" focusable="false"><path d="M24 7a12 12 0 0 0-7.5 21.4c1.4 1.1 2.3 2.3 2.5 4.1l.2 1.5h9.6l.2-1.5c.2-1.8 1.1-3 2.5-4.1A12 12 0 0 0 24 7Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/><path d="M20 38.5h8M21.5 42h5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
          {%- endif -%}
        </div>
        <h3 style="font-size:21px;font-weight:600;margin-bottom:12px">{%- if section.settings.tile_3_title != blank -%}{{ section.settings.tile_3_title }}{%- else -%}{{ 'home.problem.tile_3_title' | t }}{%- endif -%}</h3>
        <p class="body-standard text-muted">{%- if section.settings.tile_3_body != blank -%}{{ section.settings.tile_3_body }}{%- else -%}{{ 'home.problem.tile_3_body' | t }}{%- endif -%}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Problem",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    { "type": "text", "id": "tile_1_title", "label": "Tile 1 title" },
    {
      "type": "textarea",
      "id": "tile_1_body",
      "label": "Tile 1 body"
    },
    { "type": "image_picker", "id": "tile_1_image", "label": "Tile 1 image", "info": "Default: kevin-feature-problem-alarms.jpg" },
    { "type": "text", "id": "tile_2_title", "label": "Tile 2 title" },
    {
      "type": "textarea",
      "id": "tile_2_body",
      "label": "Tile 2 body"
    },
    { "type": "image_picker", "id": "tile_2_image", "label": "Tile 2 image", "info": "Default: kevin-feature-problem-cameras.jpg" },
    { "type": "text", "id": "tile_3_title", "label": "Tile 3 title" },
    {
      "type": "textarea",
      "id": "tile_3_body",
      "label": "Tile 3 body"
    },
    { "type": "image_picker", "id": "tile_3_image", "label": "Tile 3 image", "info": "Default: kevin-feature-problem-lights.jpg" }
  ],
  "presets": [{ "name": "Problem" }]
}
{% endschema %}

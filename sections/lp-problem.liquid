{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.problem.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.problem.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.problem.subheading' | t
  endif
-%}

<section id="problem" class="section-apple bg-white">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'light'
    %}

    <div class="problem-bento">
      <article class="problem-bento__lead tile tile--gray">
        <div class="nf-glyph nf-glyph--window" aria-hidden="true"><span></span></div>
        <h3 class="problem-bento__title headline-tile">
          {%- if section.settings.tile_1_title != blank -%}{{ section.settings.tile_1_title }}{%- else -%}{{ 'home.problem.tile_1_title' | t }}{%- endif -%}
        </h3>
        <p class="body-standard text-muted">
          {%- if section.settings.tile_1_body != blank -%}{{ section.settings.tile_1_body }}{%- else -%}{{ 'home.problem.tile_1_body' | t }}{%- endif -%}
        </p>
      </article>

      <article class="problem-bento__tile tile tile--gray">
        <div class="nf-glyph nf-glyph--silence" aria-hidden="true"><span></span></div>
        <h3 class="problem-bento__title headline-tile">
          {%- if section.settings.tile_2_title != blank -%}{{ section.settings.tile_2_title }}{%- else -%}{{ 'home.problem.tile_2_title' | t }}{%- endif -%}
        </h3>
        <p class="body-standard text-muted">
          {%- if section.settings.tile_2_body != blank -%}{{ section.settings.tile_2_body }}{%- else -%}{{ 'home.problem.tile_2_body' | t }}{%- endif -%}
        </p>
      </article>

      <article class="problem-bento__tile tile tile--gray">
        <div class="nf-glyph nf-glyph--timer" aria-hidden="true"><span></span></div>
        <h3 class="problem-bento__title headline-tile">
          {%- if section.settings.tile_3_title != blank -%}{{ section.settings.tile_3_title }}{%- else -%}{{ 'home.problem.tile_3_title' | t }}{%- endif -%}
        </h3>
        <p class="body-standard text-muted">
          {%- if section.settings.tile_3_body != blank -%}{{ section.settings.tile_3_body }}{%- else -%}{{ 'home.problem.tile_3_body' | t }}{%- endif -%}
        </p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Problem",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "tile_1_title", "label": "Tile 1 title" },
    { "type": "textarea", "id": "tile_1_body", "label": "Tile 1 body" },
    { "type": "text", "id": "tile_2_title", "label": "Tile 2 title" },
    { "type": "textarea", "id": "tile_2_body", "label": "Tile 2 body" },
    { "type": "text", "id": "tile_3_title", "label": "Tile 3 title" },
    { "type": "textarea", "id": "tile_3_body", "label": "Tile 3 body" },
    { "type": "image_picker", "id": "tile_3_image", "label": "Tile 3 image", "info": "Default: kevin-feature-problem-lights.jpg" }
  ],
  "presets": [{ "name": "Problem" }]
}
{% endschema %}

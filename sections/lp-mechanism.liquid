{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.mechanism.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.mechanism.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.mechanism.subheading' | t
  endif
-%}

<section id="how-it-works" class="section-apple nf-mech">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'dark'
    %}
  </div>

  {%- comment -%}
    Scroll-scrubbed stage: the CSS window motif performs the product story —
    window warms, a silhouette crosses, sound bars pulse. One 0..1 timeline
    drives every child (segments live inside the keyframes), fed either by
    CSS animation-timeline: view() or by scroll-fx.js via --nf-progress.
    Reduced motion / mobile get the designed static end-state.
  {%- endcomment -%}
  <div class="nf-mech__track" data-nf-scrub>
    <div class="nf-mech__stage">
      <div class="nf-mech__inner apple-container">
        {%- comment -%}
          Scene slider: up to three lived-in-home photos (lights → shadow →
          sound). On desktop they cross-fade along the same scroll timeline
          that drives the three phase captions; on mobile / reduced motion the
          scrub is off, so they become a swipeable carousel instead. Each slide
          falls back to the default scene photo, which falls back to the
          built-in cozy-home image — so the section works before any images are
          uploaded (it simply shows the same photo three times).
        {%- endcomment -%}
        {%- comment -%}
          Distinct per-slide built-in photos (lights → shadow → sound) so the
          slider visibly cross-fades out of the box. Each is overridden by its
          Slide 1/2/3 image picker when the merchant sets one.
        {%- endcomment -%}
        {%- assign fallback_assets = 'kevin-feature-solution-light.jpg,kevin-hero-shadow-mom-toddler.webp,kevin-cozy-home.webp' | split: ',' -%}
        <div class="nf-window nf-window--photo" aria-hidden="true">
          <div class="nf-window__slides">
            {%- for n in (1..3) -%}
              {%- liquid
                assign img_key = 'phase_' | append: n | append: '_image'
                assign slide_img = section.settings[img_key]
                assign fallback_asset = fallback_assets[forloop.index0]
              -%}
              {%- if slide_img != blank -%}
                <img class="nf-window__photo nf-window__photo--{{ n }}"
                     src="{{ slide_img | image_url: width: 1000 }}"
                     srcset="{{ slide_img | image_url: width: 600 }} 600w, {{ slide_img | image_url: width: 1000 }} 1000w"
                     sizes="(max-width: 900px) 90vw, 460px"
                     alt="" loading="lazy" width="900" height="1206">
              {%- else -%}
                <img class="nf-window__photo nf-window__photo--{{ n }}"
                     src="{{ fallback_asset | asset_url }}"
                     alt="" loading="lazy" width="900" height="1206">
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="nf-window__vignette"></span>

          {%- comment -%} Animated sound wave: mirrored equalizer, a travelling pulse. {%- endcomment -%}
          <div class="nf-soundwave">
            {%- for i in (1..32) -%}<span style="--i:{{ i }}"></span>{%- endfor -%}
          </div>
          <div class="nf-window__dots" aria-hidden="true">
            <span class="nf-window__dot nf-window__dot--1"></span>
            <span class="nf-window__dot nf-window__dot--2"></span>
            <span class="nf-window__dot nf-window__dot--3"></span>
          </div>
        </div>

        <ol class="nf-mech__phases">
          <li class="nf-mech__phase nf-mech__phase--1">
            <h3 class="nf-mech__phase-title text-white">
              {%- if section.settings.phase_1_title != blank -%}{{ section.settings.phase_1_title }}{%- else -%}{{ 'home.mechanism.phase_1_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted-dark">
              {%- if section.settings.phase_1_body != blank -%}{{ section.settings.phase_1_body }}{%- else -%}{{ 'home.mechanism.phase_1_body' | t }}{%- endif -%}
            </p>
          </li>
          <li class="nf-mech__phase nf-mech__phase--2">
            <h3 class="nf-mech__phase-title text-white">
              {%- if section.settings.phase_2_title != blank -%}{{ section.settings.phase_2_title }}{%- else -%}{{ 'home.mechanism.phase_2_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted-dark">
              {%- if section.settings.phase_2_body != blank -%}{{ section.settings.phase_2_body }}{%- else -%}{{ 'home.mechanism.phase_2_body' | t }}{%- endif -%}
            </p>
          </li>
          <li class="nf-mech__phase nf-mech__phase--3">
            <h3 class="nf-mech__phase-title text-white">
              {%- if section.settings.phase_3_title != blank -%}{{ section.settings.phase_3_title }}{%- else -%}{{ 'home.mechanism.phase_3_title' | t }}{%- endif -%}
            </h3>
            <p class="body-standard text-muted-dark">
              {%- if section.settings.phase_3_body != blank -%}{{ section.settings.phase_3_body }}{%- else -%}{{ 'home.mechanism.phase_3_body' | t }}{%- endif -%}
            </p>
          </li>
        </ol>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mechanism",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Scene slider (scrolls through 3 images)" },
    { "type": "image_picker", "id": "phase_1_image", "label": "Slide 1 — lights", "info": "Shown as the section scrolls into the ‘lights’ phase. Falls back to a built-in photo." },
    { "type": "image_picker", "id": "phase_2_image", "label": "Slide 2 — shadow", "info": "Shown at the ‘shadow’ phase. Falls back to a built-in photo." },
    { "type": "image_picker", "id": "phase_3_image", "label": "Slide 3 — sound", "info": "Shown at the ‘sound’ phase. Falls back to a built-in photo." },
    { "type": "text", "id": "phase_1_title", "label": "Phase 1 title (light)" },
    { "type": "textarea", "id": "phase_1_body", "label": "Phase 1 body" },
    { "type": "text", "id": "phase_2_title", "label": "Phase 2 title (shadow)" },
    { "type": "textarea", "id": "phase_2_body", "label": "Phase 2 body" },
    { "type": "text", "id": "phase_3_title", "label": "Phase 3 title (sound)" },
    { "type": "textarea", "id": "phase_3_body", "label": "Phase 3 body" }
  ],
  "presets": [{ "name": "Mechanism" }]
}
{% endschema %}

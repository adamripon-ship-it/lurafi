{%- liquid

  assign specs_eyebrow = section.settings.eyebrow
  if specs_eyebrow == blank
    assign specs_eyebrow = 'home.specs.eyebrow' | t
  endif
  assign specs_heading = section.settings.heading
  if specs_heading == blank
    assign specs_heading = 'home.specs.heading' | t
  endif
-%}

<section class="section-apple bg-white lp-specs" aria-labelledby="SpecsHeading-{{ section.id }}">
  <div class="apple-container">
    {% render 'section-intro',
      overline: specs_eyebrow,
      heading: specs_heading,
      subheading: blank,
      theme: 'light'
    %}

    <div class="lp-specs-full">

      <div class="lp-specs-split__rows lp-specs__card">
        <table class="lp-specs__table">
          <caption class="visually-hidden">{{ specs_heading | escape }}</caption>
          <tbody>
            {%- if section.blocks.size > 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'spec_row' -%}
                  <tr {{ block.shopify_attributes }}>
                    <th scope="row">{{ block.settings.label | escape }}</th>
                    <td>{{ block.settings.value | escape }}</td>
                  </tr>
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              <tr>
                <th scope="row">{{ 'spec_row.dimensions_label' | t }}</th>
                <td>{{ 'spec_row.dimensions_value' | t }}</td>
              </tr>
              <tr>
                <th scope="row">{{ 'spec_row.power_label' | t }}</th>
                <td>{{ 'spec_row.power_value' | t }}</td>
              </tr>
              <tr>
                <th scope="row">{{ 'spec_row.connectivity_label' | t }}</th>
                <td>{{ 'spec_row.connectivity_value' | t }}</td>
              </tr>
              <tr>
                <th scope="row">{{ 'spec_row.privacy_label' | t }}</th>
                <td>{{ 'spec_row.privacy_value' | t }}</td>
              </tr>
              <tr>
                <th scope="row">{{ 'spec_row.storage_label' | t }}</th>
                <td>{{ 'spec_row.storage_value' | t }}</td>
              </tr>
              <tr>
                <th scope="row">{{ 'spec_row.placement_label' | t }}</th>
                <td>{{ 'spec_row.placement_value' | t }}</td>
              </tr>
            {%- endif -%}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Specifications",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    }
  ],
  "blocks": [
    {
      "type": "spec_row",
      "name": "Specification row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "info": "Per language when editor language is switched." },
        { "type": "text", "id": "value", "label": "Value" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "Specifications" }]
}
{% endschema %}

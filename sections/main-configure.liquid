{%- liquid
  assign buy_product = settings.product_buy
  if buy_product == blank
    assign buy_product = all_products['kevin-plus']
  else
    if buy_product.variants == blank
      assign buy_product = all_products[settings.product_buy]
    endif
  endif
  if buy_product == blank
    assign buy_product = all_products['kevin-plus']
  endif

  # Product image (only one unit colour exists — Grey). Theme Editor picker
  # overrides the built-in asset fallback.
  if section.settings.color_image_grey != blank
    assign url_grey = section.settings.color_image_grey | image_url: width: 1200
  elsif buy_product.featured_image != blank
    assign url_grey = buy_product.featured_image | image_url: width: 1200
  else
    assign url_grey = 'kevin-front-cover-grey-v2.webp' | asset_url
  endif
  assign default_image = url_grey
  assign buy_features = 'configure.buy_features' | t | split: '|'

  assign configure_back = section.settings.back_label
  if configure_back == blank
    assign configure_back = 'configure.back' | t
  endif
  assign configure_nav_title = section.settings.nav_title
  if configure_nav_title == blank
    assign configure_nav_title = 'configure.nav_title' | t
  endif
  assign configure_header_eyebrow = section.settings.header_eyebrow
  if configure_header_eyebrow == blank
    assign configure_header_eyebrow = 'configure.header_eyebrow' | t
  endif
  assign configure_title = section.settings.title
  if configure_title == blank
    assign configure_title = 'configure.title' | t
  endif
  assign configure_lede = section.settings.lede
  if configure_lede == blank
    assign configure_lede = 'configure.lede' | t
  endif
  assign configure_checkout_cta = section.settings.checkout_cta
  if configure_checkout_cta == blank
    assign configure_checkout_cta = 'configure.checkout_cta' | t
  endif
-%}

<section class="configure-page" data-configure>
  <nav class="configure-nav" aria-label="{{ 'accessibility.configure_navigation' | t }}">
    <div class="configure-nav__inner apple-container">
      <a href="{{ routes.root_url }}" class="configure-nav__back">
        <svg width="8" height="13" viewBox="0 0 8 13" fill="none" aria-hidden="true">
          <path d="M7 1L1.5 6.5L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ configure_back }}
      </a>
      <span class="configure-nav__title">{{ configure_nav_title }}</span>
      <div class="configure-nav__tools">
        {% render 'language-selector', form_id: 'ConfigureLanguageForm', selector_id: 'ConfigureLanguageSelector' %}
      </div>
      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart configure-nav__cart" aria-label="{{ 'configure.cart' | t }}">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M3.5 5h11l-1.1 8.4a1.5 1.5 0 0 1-1.5 1.3H6.1a1.5 1.5 0 0 1-1.5-1.3L3.5 5z"/>
          <path d="M6.5 5V3.75a2.5 2.5 0 0 1 5 0V5"/>
        </svg>
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </nav>

  <div class="configure-stepper-wrap apple-container" aria-label="{{ 'accessibility.configure_steps' | t | default: 'Checkout steps' }}">
    <ol class="configure-stepper" role="list">
      <li class="configure-stepper__item is-active" aria-current="step">
        <span class="configure-stepper__num" aria-hidden="true">1</span>
        <span class="configure-stepper__label">{{ 'configure.step_configure' | t }}</span>
      </li>
      <li class="configure-stepper__connector" aria-hidden="true"></li>
      <li class="configure-stepper__item">
        <span class="configure-stepper__num" aria-hidden="true">2</span>
        <span class="configure-stepper__label">{{ 'configure.step_checkout' | t }}</span>
      </li>
    </ol>
  </div>

  <div class="apple-container configure-page__inner">
    <header class="configure-header">
      <p class="configure-header__eyebrow">{{ configure_header_eyebrow }}</p>
      <h1 class="configure-header__title">{{ configure_title }}</h1>
      <p class="configure-header__lede">{{ configure_lede }}</p>
    </header>

    <div class="configure-grid">
      <div class="configure-gallery">
        <div class="configure-gallery__well">
          <div class="configure-gallery__glow" aria-hidden="true"></div>
          <img
            src="{{ default_image }}"
            alt="{{ 'configure.device_alt' | t }}"
            class="configure-gallery__img"
            data-configure-image
            width="420"
            height="420"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          >
          <p class="configure-gallery__chip">
            <span class="configure-gallery__chip-dot" data-configure-chip-dot aria-hidden="true"></span>
            <span data-configure-color-name>Grey</span>
          </p>
        </div>
      </div>

      <div class="configure-controls">
        <section class="configure-section" aria-labelledby="ConfigureColorHeading">
          <h2 id="ConfigureColorHeading" class="configure-label">{{ 'configure.device_heading' | t }}</h2>
          <div class="configure-swatches" data-configure-swatches role="group" aria-label="{{ 'accessibility.color_swatches' | t }}"></div>
          <p class="configure-color-text">{{ 'configure.device_colour_label' | t }} <strong data-configure-color-name-inline>Grey</strong></p>
        </section>

        {%- comment -%}
          Optional paid front covers (add-on line items). The device is Grey; a
          cover clips on top to change the look. Images/names are editable in the
          Theme Editor; a cover is only purchasable once its Shopify variant id is
          set (the cover products must exist in Shopify). Covers without an id are
          shown but marked "soon".
          Default image mapping (owner-provided): Red=download_24, Brown=download_25,
          Blue=download_29, White=download_27.
        {%- endcomment -%}
        {%- comment -%}
          Cover price shown in the shopper's market currency (EUR base,
          CHF fixed via the Switzerland price list) when the cover product
          resolves; the label setting is only a fallback.
        {%- endcomment -%}
        {%- liquid
          assign cover_product = all_products['kevin-front-cover']
          assign cover_price_cents = 0
          if cover_product != blank and cover_product.price_min > 0
            assign cover_price_label = cover_product.price_min | money
            assign cover_price_cents = cover_product.price_min
          else
            assign cover_price_label = section.settings.cover_price_label | default: '29.00 CHF · 31.50 EUR'
          endif
          assign covers_heading = 'configure.covers_heading' | t
        -%}
        <section class="configure-section configure-covers" data-configure-covers aria-labelledby="ConfigureCoversHeading">
          <h2 id="ConfigureCoversHeading" class="configure-label">{{ covers_heading }}</h2>
          <p class="configure-covers__note">{{ 'configure.covers_note' | t: price: cover_price_label }}</p>
          <p class="configure-covers__note configure-covers__note--sub">{{ 'configure.covers_included' | t }}</p>
          <div class="configure-covers__grid" role="group" aria-label="{{ covers_heading }}">
            {% render 'configure-cover', cover_name: section.settings.cover_1_name, default_name: 'Red', cover_variant: section.settings.cover_1_variant, cover_image: section.settings.cover_1_image, default_img: 'https://cdn.shopify.com/s/files/1/0943/9841/5226/files/download_24.png?v=1783616627', price_label: cover_price_label, price_cents: cover_price_cents %}
            {% render 'configure-cover', cover_name: section.settings.cover_2_name, default_name: 'Brown', cover_variant: section.settings.cover_2_variant, cover_image: section.settings.cover_2_image, default_img: 'https://cdn.shopify.com/s/files/1/0943/9841/5226/files/download_25.png?v=1783616628', price_label: cover_price_label, price_cents: cover_price_cents %}
            {% render 'configure-cover', cover_name: section.settings.cover_3_name, default_name: 'Blue', cover_variant: section.settings.cover_3_variant, cover_image: section.settings.cover_3_image, default_img: 'https://cdn.shopify.com/s/files/1/0943/9841/5226/files/download_29.png?v=1783616628', price_label: cover_price_label, price_cents: cover_price_cents %}
            {% render 'configure-cover', cover_name: section.settings.cover_4_name, default_name: 'White', cover_variant: section.settings.cover_4_variant, cover_image: section.settings.cover_4_image, default_img: 'https://cdn.shopify.com/s/files/1/0943/9841/5226/files/download_27.png?v=1783616628', price_label: cover_price_label, price_cents: cover_price_cents %}
          </div>
        </section>

        <section class="configure-section configure-section--compact" data-configure-qty aria-labelledby="ConfigureQtyHeading">
          <h2 id="ConfigureQtyHeading" class="configure-label">{{ 'configure.quantity' | t }}</h2>
          <div class="configure-qty" role="group" aria-label="{{ 'configure.quantity' | t }}">
            <button type="button" class="configure-qty__btn" data-configure-qty-minus aria-label="{{ 'accessibility.decrease_qty' | t }}">
              <svg width="12" height="2" viewBox="0 0 12 2" fill="none" aria-hidden="true"><path d="M1 1h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <span class="configure-qty__value" data-configure-qty-value aria-live="polite">1</span>
            <button type="button" class="configure-qty__btn" data-configure-qty-plus aria-label="{{ 'accessibility.increase_qty' | t }}">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
          </div>
          <p class="configure-qty__hint">{{ 'configure.qty_hint' | t }}</p>
        </section>

        <section class="configure-section configure-section--features" aria-labelledby="ConfigureIncludedHeading">
          <h2 id="ConfigureIncludedHeading" class="configure-label">{{ 'configure.included' | t }}</h2>
          <ul class="configure-features" data-configure-features></ul>
        </section>

        <aside class="configure-summary configure-checkout-panel" id="ConfigureSummary" aria-label="{{ 'accessibility.checkout_summary' | t }}">
          <div class="configure-order-card" aria-label="{{ 'accessibility.order_summary' | t }}">
            <div class="configure-order-card__head">
              <p class="configure-order-card__label">{{ 'configure.order_summary' | t }}</p>
              <p class="configure-order-card__title">{{ 'configure.product_title' | t }}</p>
            </div>
            <dl class="configure-order-card__list">
              <div>
                <dt>{{ 'configure.summary_front' | t }}</dt>
                <dd data-configure-summary-color>Grey</dd>
              </div>
              <div>
                <dt>{{ 'configure.summary_plan' | t }}</dt>
                <dd data-configure-summary-plan>{{ 'configure.summary_plan_buy' | t }}</dd>
              </div>
              <div>
                <dt>{{ 'configure.summary_delivery' | t }}</dt>
                <dd class="configure-order-card__highlight">{{ 'configure.delivery_free' | t }}</dd>
              </div>
            </dl>
          </div>

          <div class="configure-summary__total-block">
            <div class="configure-summary__row">
              <div>
                <p class="configure-summary__label">{{ 'configure.total' | t }}</p>
                <p class="configure-summary__total">
                  <span data-configure-total>—</span>
                  <span class="configure-summary__suffix" data-configure-total-suffix></span>
                </p>
              </div>
              <p class="configure-summary__per" data-configure-per-device hidden></p>
            </div>
            <button type="button" class="btn-apple-primary btn-block configure-cta" data-configure-checkout>
              <span data-configure-cta-label>{{ configure_checkout_cta }}</span>
              <svg class="configure-cta__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <p class="configure-summary__trust" role="alert" data-configure-error hidden></p>
          </div>

          <div class="checkout-assurance configure-summary__assurance" aria-label="{{ 'accessibility.checkout_benefits' | t }}">
            <p>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9l9-6 9 6v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9z" stroke="currentColor" stroke-width="1.5"/><path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.5"/></svg>
              {{ 'configure.free_delivery' | t }}
            </p>
            <p>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12a8 8 0 1 0 16 0" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              {{ 'configure.returns' | t }}
            </p>
            <p>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 4v6c0 4.5-3.2 7.8-7 8-3.8-.2-7-3.5-7-8V7l7-4z" stroke="currentColor" stroke-width="1.5"/></svg>
              {{ 'configure.warranty' | t }}
            </p>
          </div>
          <p class="configure-summary__secure">
            <svg width="12" height="14" viewBox="0 0 12 14" fill="none" aria-hidden="true"><rect x="1" y="6" width="10" height="7" rx="1" stroke="currentColor"/><path d="M3 6V4a3 3 0 0 1 6 0v2" stroke="currentColor"/></svg>
            {{ 'configure.secure' | t }}
          </p>
        </aside>
      </div>
    </div>
  </div>

  <aside class="configure-sticky-checkout" aria-label="{{ 'accessibility.checkout_summary' | t }}" data-configure-sticky-checkout>
    <div class="configure-sticky-checkout__inner">
      <div class="configure-sticky-checkout__meta">
        <span class="configure-sticky-checkout__color" data-configure-sticky-color>Grey</span>
        <div class="configure-sticky-checkout__price">
          <span class="configure-sticky-checkout__label">{{ 'configure.total' | t }}</span>
          <strong>
            <span data-configure-sticky-total>—</span>
            <span data-configure-sticky-total-suffix></span>
          </strong>
        </div>
      </div>
      <button type="button" class="btn-apple-primary configure-sticky-checkout__btn" data-configure-checkout>
        <span data-configure-cta-label>{{ 'configure.sticky_checkout' | t }}</span>
        <svg class="configure-cta__arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </aside>
</section>

<script id="ConfigureData" type="application/json">
{
  "defaultImage": {{ default_image | json }},
  "moneyFormat": {{ shop.money_format | json }},
  "currency": {{ cart.currency.iso_code | default: localization.country.currency.iso_code | json }},
  "colorHex": {
    "grey": "#817976"
  },
  "colorImages": {
    "grey": {{ url_grey | json }}
  },
  "buy": {
    "features": {{ buy_features | json }},
    "variants": [
      {%- comment -%}
        Only one unit colour exists (Grey). Show just the Grey variant; if the
        product has no variant literally named "Grey", fall back to the first
        variant so the picker and checkout never break.
      {%- endcomment -%}
      {%- if buy_product != blank -%}
        {%- assign grey_variants = buy_product.variants | where: 'option1', 'Grey' -%}
        {%- if grey_variants.size == 0 -%}
          {%- assign grey_variants = buy_product.variants | slice: 0, 1 -%}
        {%- endif -%}
        {%- for variant in grey_variants -%}
          {
            "id": {{ variant.id }},
            "color": {{ variant.option1 | default: variant.title | json }},
            "price": {{ variant.price }},
            "available": {{ variant.available | json }},
            "image": null
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      {%- else -%}
        {"id":"preview-grey","color":"Grey","price":64900,"available":true,"image":null}
      {%- endif -%}
    ]
  }
}
</script>

{% render 'cart-checkout-variant-guard' %}

{% schema %}
{
  "name": "Configure",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "header", "content": "Navigation" },
    { "type": "text", "id": "back_label", "label": "Back link label" },
    { "type": "text", "id": "nav_title", "label": "Nav title" },
    { "type": "header", "content": "Page header" },
    { "type": "text", "id": "header_eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "title", "label": "Page title" },
    { "type": "textarea", "id": "lede", "label": "Introduction" },
    { "type": "header", "content": "Product image" },
    { "type": "image_picker", "id": "color_image_grey", "label": "Product photo (Grey)", "info": "Only one unit colour exists. Blank keeps the shipped image." },
    { "type": "header", "content": "Optional front covers (paid add-ons)" },
    { "type": "paragraph", "content": "Covers show on the configure page. Each becomes purchasable only when its Shopify variant ID is filled in below (the cover product must exist in Shopify)." },
    { "type": "text", "id": "cover_price_label", "label": "Cover price label", "default": "29.00 CHF · 31.50 EUR" },
    { "type": "text", "id": "cover_1_name", "label": "Cover 1 name", "default": "Red" },
    { "type": "image_picker", "id": "cover_1_image", "label": "Cover 1 image (blank = built-in)" },
    { "type": "text", "id": "cover_1_variant", "label": "Cover 1 Shopify variant ID" },
    { "type": "text", "id": "cover_2_name", "label": "Cover 2 name", "default": "Brown" },
    { "type": "image_picker", "id": "cover_2_image", "label": "Cover 2 image (blank = built-in)" },
    { "type": "text", "id": "cover_2_variant", "label": "Cover 2 Shopify variant ID" },
    { "type": "text", "id": "cover_3_name", "label": "Cover 3 name", "default": "Blue" },
    { "type": "image_picker", "id": "cover_3_image", "label": "Cover 3 image (blank = built-in)" },
    { "type": "text", "id": "cover_3_variant", "label": "Cover 3 Shopify variant ID" },
    { "type": "text", "id": "cover_4_name", "label": "Cover 4 name", "default": "White" },
    { "type": "image_picker", "id": "cover_4_image", "label": "Cover 4 image (blank = built-in)" },
    { "type": "text", "id": "cover_4_variant", "label": "Cover 4 Shopify variant ID" },
    { "type": "header", "content": "Checkout" },
    { "type": "text", "id": "checkout_cta", "label": "Checkout button label" }
  ],
  "presets": [{ "name": "Configure" }]
}
{% endschema %}

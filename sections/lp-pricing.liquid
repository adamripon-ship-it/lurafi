{%- liquid
  assign buy_product = settings.product_buy
  assign buy_features_raw = section.settings.buy_features | strip
  if buy_features_raw != blank
    assign buy_features = buy_features_raw | split: '|'
  else
    assign buy_features = 'home.pricing.buy_features' | t | split: '|'
  endif
  capture configure_buy_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_buy_url = configure_buy_url | strip
-%}

<section id="pricing" class="section-apple bg-white">
  <div class="apple-container">
    {%- liquid
      assign pricing_overline = section.settings.overline
      if pricing_overline == blank
        assign pricing_overline = 'home.pricing.overline' | t
      endif
      assign pricing_heading = section.settings.heading
      if pricing_heading == blank
        assign pricing_heading = 'home.pricing.heading' | t
      endif
      assign pricing_subheading = section.settings.subheading
      if pricing_subheading == blank
        assign pricing_subheading = 'home.pricing.subheading' | t
      endif
    -%}
    {% render 'section-intro',
      overline: pricing_overline,
      heading: pricing_heading,
      subheading: pricing_subheading,
      theme: 'light',
      subhead_narrow: true
    %}

    <div class="pricing-plans pricing-plans--single">
      <div class="tile tile--gray plan-card plan-card--featured">
        <span class="plan-card__badge">{{ 'configure.plan_badge_popular' | t }}</span>
        <p class="plan-label plan-label--blue">{%- if section.settings.buy_label != blank -%}{{ section.settings.buy_label }}{%- else -%}{{ 'home.pricing.buy_label' | t }}{%- endif -%}</p>
        <h3 class="plan-card__title">{{ buy_product.title | default: 'Kevin' }}</h3>
        <p class="plan-card__tagline text-muted">{%- if section.settings.buy_tagline != blank -%}{{ section.settings.buy_tagline }}{%- else -%}{{ 'home.pricing.buy_tagline' | t }}{%- endif -%}</p>
        <p class="plan-price">
          {% render 'price-display', product: buy_product, fallback: '649 EUR' %}
        </p>
        <ul class="plan-features">
          {%- for feature in buy_features -%}
            <li>
              {% render 'plan-feature-icon' %}
              <span>{{ feature | strip }}</span>
            </li>
          {%- endfor -%}
        </ul>
        <a href="{{ configure_buy_url }}" class="btn-apple-primary btn-block">{%- if section.settings.buy_cta != blank -%}{{ section.settings.buy_cta }}{%- else -%}{{ 'home.pricing.buy_cta' | t }}{%- endif -%}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pricing",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "header", "content": "Section copy" },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Buy plan (Kevin)" },
    { "type": "text", "id": "buy_label", "label": "Plan label" },
    { "type": "text", "id": "buy_tagline", "label": "Tagline" },
    { "type": "text", "id": "buy_cta", "label": "Button label" },
    { "type": "textarea", "id": "buy_features", "label": "Feature list (pipe-separated)", "info": "Example: Feature one|Feature two|Feature three" }
  ],
  "presets": [{ "name": "Pricing" }]
}
{% endschema %}

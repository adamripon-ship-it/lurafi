<section class="stats-section section-apple bg-white">
  <div class="apple-container">
    {%- liquid
      assign stats_heading = section.settings.heading
      if stats_heading == blank
        assign stats_heading = 'home.stats.heading' | t
      endif
    -%}
    {% render 'section-intro',
      heading: stats_heading,
      subheading: blank,
      theme: 'light',
      compact: true
    %}
    <div class="stats-grid-4" data-countup-duration="1100">
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_1_value != blank -%}{{ section.settings.stat_1_value }}{%- else -%}{{ 'home.stats.stat_1_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_1_label != blank -%}{{ section.settings.stat_1_label }}{%- else -%}{{ 'home.stats.stat_1_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_2_value != blank -%}{{ section.settings.stat_2_value }}{%- else -%}{{ 'home.stats.stat_2_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_2_label != blank -%}{{ section.settings.stat_2_label }}{%- else -%}{{ 'home.stats.stat_2_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_3_value != blank -%}{{ section.settings.stat_3_value }}{%- else -%}{{ 'home.stats.stat_3_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_3_label != blank -%}{{ section.settings.stat_3_label }}{%- else -%}{{ 'home.stats.stat_3_label' | t }}{%- endif -%}</p></div>
      <div class="text-center"><p class="stat-item__value" data-countup>{%- if section.settings.stat_4_value != blank -%}{{ section.settings.stat_4_value }}{%- else -%}{{ 'home.stats.stat_4_value' | t }}{%- endif -%}</p><p class="stat-item__label">{%- if section.settings.stat_4_label != blank -%}{{ section.settings.stat_4_label }}{%- else -%}{{ 'home.stats.stat_4_label' | t }}{%- endif -%}</p></div>
    </div>
    <div class="trust-badges">
      <span class="swiss-made-badge">
        <svg class="swiss-made-badge__icon" width="22" height="22" viewBox="0 0 22 22" aria-hidden="true" focusable="false">
          <rect width="22" height="22" rx="5" fill="#e11d2e"/>
          <path d="M9.4 5.6h3.2v3.8h3.8v3.2h-3.8v3.8H9.4v-3.8H5.6V9.4h3.8V5.6z" fill="#fff"/>
        </svg>
        <span>{{ 'stats.swiss_engineered' | t }}</span>
      </span>
      <span class="trust-badges__item">{{ 'home.stats.badge_1' | t }}</span>
      <span class="trust-badges__item">{{ 'home.stats.badge_3' | t }}</span>
      <span class="trust-badges__item">{{ 'home.stats.badge_4' | t }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 value" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 value" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 value" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label" },
    { "type": "text", "id": "stat_4_value", "label": "Stat 4 value" },
    { "type": "text", "id": "stat_4_label", "label": "Stat 4 label" }
  ],
  "presets": [{ "name": "Stats" }]
}
{% endschema %}

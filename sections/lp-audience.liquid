{%- liquid
  assign overline = section.settings.overline
  if overline == blank
    assign overline = 'home.audience.overline' | t
  endif
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'home.audience.heading' | t
  endif
  assign subheading = section.settings.subheading
  if subheading == blank
    assign subheading = 'home.audience.subheading' | t
  endif
  assign chips_raw = section.settings.chips
  if chips_raw == blank
    assign chips_raw = 'home.audience.chips' | t
  endif
  # Shopify-stored copy can arrive pre-encoded; decode before the | escape
  # at render so entities never double-encode into visible &#39; / &amp;.
  assign chips_raw = chips_raw | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
  assign chips = chips_raw | split: '|'
  assign story = section.settings.story
  if story == blank
    assign story = 'home.audience.story' | t
  endif
  assign story = story | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"'
-%}

<section id="personas" class="section-apple nf-audience">
  <div class="apple-container">
    {% render 'section-intro',
      overline: overline,
      heading: heading,
      subheading: subheading,
      theme: 'dark'
    %}

    <ul class="nf-chip-wall" role="list">
      {%- for chip in chips -%}
        <li class="nf-chip">{{ chip | strip | escape }}</li>
      {%- endfor -%}
    </ul>

    {%- if story != blank -%}
      <p class="nf-audience__story">{{ story | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Who it's for",
  "settings": [
    {
      "type": "paragraph",
      "content": "Switch language at the top of the editor before editing text. Blank fields keep the built-in translation for that language."
    },
    { "type": "text", "id": "overline", "label": "Overline" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    {
      "type": "textarea",
      "id": "chips",
      "label": "Audience chips (pipe-separated)",
      "info": "e.g. Families on holiday|Expats abroad|Living alone"
    },
    { "type": "textarea", "id": "story", "label": "Featured micro-story" }
  ],
  "presets": [{ "name": "Who it's for" }]
}
{% endschema %}

{%- liquid
  capture configure_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_url = configure_url | strip
  assign cta_primary_url = section.settings.cta_primary_url | strip
  if cta_primary_url == blank or cta_primary_url contains '/pages/configure' and pages.configure == blank
    assign cta_primary_url = configure_url
  endif

  assign cta_secondary_url = section.settings.cta_secondary_url | default: '#how-it-works'
  assign cta_primary_label = section.settings.cta_primary_label
  if cta_primary_label == blank
    assign cta_primary_label = 'home.hero.cta_primary_label' | t
  endif
  assign cta_secondary_label = section.settings.cta_secondary_label
  if cta_secondary_label == blank
    assign cta_secondary_label = 'home.hero.cta_secondary_label' | t
  endif

  assign hero_headline = section.settings.headline
  if hero_headline == blank
    assign hero_headline = 'home.hero.headline' | t
  endif

  assign hero_lede = section.settings.lede
  if hero_lede == blank
    assign hero_lede = 'home.hero.lede' | t
  endif
  if hero_lede == blank
    assign hero_lede = 'hero.slide_1.lede' | t
  endif

  assign image_alt = section.settings.image_alt
  if image_alt == blank
    assign image_alt = 'hero.slide_1.image_alt' | t
  endif
-%}

<section class="hero-apple" aria-labelledby="HeroHeading">
  {%- if section.settings.deploy_cache_bust != blank -%}
    <!-- hero-cache: {{ section.settings.deploy_cache_bust }} -->
  {%- endif -%}

  <div class="hero-apple__content">
    <div class="hero-apple__frame">
      <div class="hero-apple__stage">
        {% render 'hero-banner',
          hero_headline: hero_headline,
          hero_lede: hero_lede,
          cta_primary_url: cta_primary_url,
          cta_primary_label: cta_primary_label,
          cta_secondary_url: cta_secondary_url,
          cta_secondary_label: cta_secondary_label,
          image: section.settings.image,
          image_alt: image_alt
        %}
      </div>
    </div>
    <a href="#problem" class="hero-apple__scroll" aria-label="{{ 'accessibility.scroll_to_content' | t }}">
      <span class="hero-apple__scroll-label">{{ 'accessibility.scroll_to_content' | t }}</span>
      <span class="hero-apple__scroll-icon" aria-hidden="true">
        <span class="hero-apple__scroll-dot"></span>
      </span>
    </a>
  </div>
</section>

{% render 'cro-sticky-cta',
  sticky_label: section.settings.sticky_cta_label,
  sticky_enabled: section.settings.sticky_cta_enabled,
  sticky_url: section.settings.sticky_cta_url
%}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    { "type": "text", "id": "headline", "label": "Headline" },
    {
      "type": "textarea",
      "id": "lede",
      "label": "USP / subhead",
      "info": "Short value proposition under the headline."
    },
    { "type": "text", "id": "cta_primary_label", "label": "Primary button" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary button" },
    { "type": "text", "id": "cta_secondary_url", "label": "Secondary link (anchor OK)", "default": "#how-it-works" },
    {
      "type": "header",
      "content": "Product image"
    },
    { "type": "image_picker", "id": "image", "label": "Product image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    {
      "type": "header",
      "content": "Sticky mobile CTA"
    },
    {
      "type": "checkbox",
      "id": "sticky_cta_enabled",
      "label": "Show sticky buy button on mobile",
      "default": true
    },
    {
      "type": "text",
      "id": "sticky_cta_label",
      "label": "Sticky button label"
    },
    {
      "type": "url",
      "id": "sticky_cta_url",
      "label": "Sticky button URL",
      "info": "Leave blank to use Configure (buy) page."
    },
    {
      "type": "text",
      "id": "deploy_cache_bust",
      "label": "Deploy cache bust (internal)",
      "info": "Updated automatically by deploy scripts. Do not edit manually."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

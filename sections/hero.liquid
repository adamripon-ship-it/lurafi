{%- liquid
  capture configure_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_url = configure_url | strip
  assign cta_primary_url = section.settings.cta_primary_url | strip
  if cta_primary_url == blank or cta_primary_url contains '/pages/configure' and pages.configure == blank
    assign cta_primary_url = configure_url
  endif

  assign callouts_aria_label = section.settings.callouts_aria_label
  if callouts_aria_label == blank
    assign callouts_aria_label = 'hero.callouts_aria_label' | t
  endif

  assign carousel_label = section.settings.carousel_label
  if carousel_label == blank
    assign carousel_label = 'hero.carousel_label' | t
  endif

  assign slide_count = section.blocks.size
  assign autoplay_ms = section.settings.autoplay_seconds | times: 1000
-%}

<section class="hero-apple" aria-labelledby="HeroHeading">
  <div class="hero-apple__glow" aria-hidden="true"></div>
  <div class="hero-apple__grain" aria-hidden="true"></div>

  <div class="hero-apple__content">
    <div class="hero-apple__text">
      <p class="overline-blue-dark">{%- if section.settings.eyebrow != blank -%}{{ section.settings.eyebrow }}{%- else -%}{{ 'home.hero.eyebrow' | t }}{%- endif -%}</p>

      <h1 class="headline-hero hero-apple__headline" id="HeroHeading">
        {%- if section.settings.headline != blank -%}{{ section.settings.headline | escape }}{%- else -%}{{ 'home.hero.headline' | t | escape }}{%- endif -%}
      </h1>

      <p class="body-elevated hero-apple__sub">{%- if section.settings.lede != blank -%}{{ section.settings.lede }}{%- else -%}{{ 'home.hero.lede' | t }}{%- endif -%}</p>

      <div class="hero-apple__ctas">
        <a href="{{ cta_primary_url }}" class="btn-apple-blue">
          {%- if section.settings.cta_primary_label != blank -%}{{ section.settings.cta_primary_label }}{%- else -%}{{ 'home.hero.cta_primary_label' | t }}{%- endif -%}
        </a>
        <a href="{{ section.settings.cta_secondary_url | default: '#how-it-works' }}" class="link-apple-blue">
          {%- if section.settings.cta_secondary_label != blank -%}{{ section.settings.cta_secondary_label }}{%- else -%}{{ 'home.hero.cta_secondary_label' | t }}{%- endif -%}
          <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
            <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div
      class="hero-apple__product hero-slider"
      {% if slide_count > 1 %}
        data-hero-slider
        data-autoplay-ms="{{ autoplay_ms }}"
        data-label-pause="{{ 'hero.pause_autoplay' | t | escape }}"
        data-label-play="{{ 'hero.play_autoplay' | t | escape }}"
        role="region"
        aria-roledescription="carousel"
        aria-label="{{ carousel_label | escape }}"
      {% endif %}
    >
      <div class="hero-slider__stage">
        {%- if slide_count > 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign slide_prefix = 'hero.slide_' | append: forloop.index

              assign slide_label = block.settings.slide_label
              if slide_label == blank
                assign slide_label_key = slide_prefix | append: '.label'
                assign slide_label = slide_label_key | t
              endif

              assign image_alt = block.settings.image_alt
              if image_alt == blank
                assign image_alt_key = slide_prefix | append: '.image_alt'
                assign image_alt = image_alt_key | t
              endif

              assign callout_1_eyebrow = block.settings.callout_1_eyebrow
              if callout_1_eyebrow == blank
                assign callout_1_key = slide_prefix | append: '.callout_1_eyebrow'
                assign callout_1_eyebrow = callout_1_key | t
              endif
              assign callout_1_title = block.settings.callout_1_title
              if callout_1_title == blank
                assign callout_1_key = slide_prefix | append: '.callout_1_title'
                assign callout_1_title = callout_1_key | t
              endif
              assign callout_1_body = block.settings.callout_1_body
              if callout_1_body == blank
                assign callout_1_key = slide_prefix | append: '.callout_1_body'
                assign callout_1_body = callout_1_key | t
              endif

              assign callout_2_eyebrow = block.settings.callout_2_eyebrow
              if callout_2_eyebrow == blank
                assign callout_2_key = slide_prefix | append: '.callout_2_eyebrow'
                assign callout_2_eyebrow = callout_2_key | t
              endif
              assign callout_2_title = block.settings.callout_2_title
              if callout_2_title == blank
                assign callout_2_key = slide_prefix | append: '.callout_2_title'
                assign callout_2_title = callout_2_key | t
              endif
              assign callout_2_body = block.settings.callout_2_body
              if callout_2_body == blank
                assign callout_2_key = slide_prefix | append: '.callout_2_body'
                assign callout_2_body = callout_2_key | t
              endif

              assign callout_3_eyebrow = block.settings.callout_3_eyebrow
              if callout_3_eyebrow == blank
                assign callout_3_key = slide_prefix | append: '.callout_3_eyebrow'
                assign callout_3_eyebrow = callout_3_key | t
              endif
              assign callout_3_title = block.settings.callout_3_title
              if callout_3_title == blank
                assign callout_3_key = slide_prefix | append: '.callout_3_title'
                assign callout_3_title = callout_3_key | t
              endif
              assign callout_3_body = block.settings.callout_3_body
              if callout_3_body == blank
                assign callout_3_key = slide_prefix | append: '.callout_3_body'
                assign callout_3_body = callout_3_key | t
              endif
            -%}
            {% render 'hero-slide',
              block_id: block.id,
              is_active: forloop.first,
              is_first: forloop.first,
              slide_label: slide_label,
              image: block.settings.image,
              image_alt: image_alt,
              image_fallback: block.settings.image_fallback,
              callouts_aria_label: callouts_aria_label,
              callout_1_eyebrow: callout_1_eyebrow,
              callout_1_title: callout_1_title,
              callout_1_body: callout_1_body,
              callout_2_eyebrow: callout_2_eyebrow,
              callout_2_title: callout_2_title,
              callout_2_body: callout_2_body,
              callout_3_eyebrow: callout_3_eyebrow,
              callout_3_title: callout_3_title,
              callout_3_body: callout_3_body
            %}
          {%- endfor -%}
        {%- else -%}
          {%- liquid
            assign fallback_slide_label = 'hero.slide_1.label' | t
            assign fallback_image_alt = 'home.hero.image_alt' | t
            assign fallback_c1e = 'hero.away_eyebrow' | t
            assign fallback_c1t = 'hero.away_title' | t
            assign fallback_c1b = 'hero.away_body' | t
            assign fallback_c2e = 'hero.privacy_eyebrow' | t
            assign fallback_c2t = 'hero.privacy_title' | t
            assign fallback_c2b = 'hero.privacy_body' | t
            assign fallback_c3e = 'hero.checkout_eyebrow' | t
            assign fallback_c3t = 'hero.checkout_title' | t
            assign fallback_c3b = 'hero.checkout_body' | t
          -%}
          {% render 'hero-slide',
            block_id: section.id,
            is_active: true,
            is_first: true,
            slide_label: fallback_slide_label,
            image: blank,
            image_alt: fallback_image_alt,
            image_fallback: 'burglary',
            callouts_aria_label: callouts_aria_label,
            callout_1_eyebrow: fallback_c1e,
            callout_1_title: fallback_c1t,
            callout_1_body: fallback_c1b,
            callout_2_eyebrow: fallback_c2e,
            callout_2_title: fallback_c2t,
            callout_2_body: fallback_c2b,
            callout_3_eyebrow: fallback_c3e,
            callout_3_title: fallback_c3t,
            callout_3_body: fallback_c3b
          %}
        {%- endif -%}
      </div>

      {%- if slide_count > 1 -%}
        <div class="hero-slider__toolbar" data-hero-slider-controls hidden>
          <div
            class="visually-hidden"
            data-hero-slider-live
            aria-live="polite"
            aria-atomic="true"
          ></div>
          <div class="hero-slider__controls">
            <button
              type="button"
              class="hero-slider__nav hero-slider__nav--prev"
              data-hero-slider-prev
              aria-label="{{ 'hero.previous_slide' | t | escape }}"
            >
              <span aria-hidden="true">‹</span>
            </button>
            <div class="hero-slider__dots" data-hero-slider-dots role="tablist" aria-label="{{ carousel_label | escape }}"></div>
            <button
              type="button"
              class="hero-slider__nav hero-slider__nav--next"
              data-hero-slider-next
              aria-label="{{ 'hero.next_slide' | t | escape }}"
            >
              <span aria-hidden="true">›</span>
            </button>
          </div>
          <div class="hero-slider__progress-track" aria-hidden="true">
            <div class="hero-slider__progress-bar" data-hero-slider-progress></div>
          </div>
          <button
            type="button"
            class="hero-slider__pause"
            data-hero-slider-pause
            aria-pressed="false"
            aria-label="{{ 'hero.pause_autoplay' | t | escape }}"
            hidden
          >
            <span class="hero-slider__pause-icon hero-slider__pause-icon--pause" aria-hidden="true"></span>
            <span class="hero-slider__pause-label">{{ 'hero.pause_autoplay' | t }}</span>
          </button>
        </div>
      {%- endif -%}
    </div>

    <a href="#problem" class="hero-apple__scroll" aria-label="{{ 'accessibility.scroll_to_content' | t }}">
      <span class="hero-apple__scroll-icon" aria-hidden="true">
        <span class="hero-apple__scroll-dot"></span>
      </span>
    </a>
  </div>
</section>

{% render 'cro-sticky-cta',
  sticky_label: section.settings.sticky_cta_label,
  sticky_enabled: section.settings.sticky_cta_enabled,
  sticky_url: section.settings.sticky_cta_url
%}

{%- if slide_count > 1 -%}
  <script src="{{ 'hero-slider.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "settings": [
        {
          "type": "paragraph",
          "content": "Location-based hero images: use docs/HERO-IMAGE-PROMPTS.md — Dutch/German towns only, correct window geometry, no skyscrapers."

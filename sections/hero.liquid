{%- liquid
  assign hero_image = section.settings.image
  assign hero_image_url = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663143838195/XAqmtb4V6fmS5cL6eq54xv/lurafi-device-angle-transparent-feBmUBJ5mWe9dTyXfTHnUU.webp'
  capture configure_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_url = configure_url | strip
  assign cta_primary_url = section.settings.cta_primary_url | strip
  if cta_primary_url == blank or cta_primary_url contains '/pages/configure' and pages.configure == blank
    assign cta_primary_url = configure_url
  endif

  assign away_eyebrow = section.settings.away_eyebrow
  if away_eyebrow == blank
    assign away_eyebrow = 'hero.away_eyebrow' | t
  endif
  assign away_title = section.settings.away_title
  if away_title == blank
    assign away_title = 'hero.away_title' | t
  endif
  assign away_body = section.settings.away_body
  if away_body == blank
    assign away_body = 'hero.away_body' | t
  endif

  assign privacy_eyebrow = section.settings.privacy_eyebrow
  if privacy_eyebrow == blank
    assign privacy_eyebrow = 'hero.privacy_eyebrow' | t
  endif
  assign privacy_title = section.settings.privacy_title
  if privacy_title == blank
    assign privacy_title = 'hero.privacy_title' | t
  endif
  assign privacy_body = section.settings.privacy_body
  if privacy_body == blank
    assign privacy_body = 'hero.privacy_body' | t
  endif

  assign checkout_eyebrow = section.settings.checkout_eyebrow
  if checkout_eyebrow == blank
    assign checkout_eyebrow = 'hero.checkout_eyebrow' | t
  endif
  assign checkout_title = section.settings.checkout_title
  if checkout_title == blank
    assign checkout_title = 'hero.checkout_title' | t
  endif
  assign checkout_body = section.settings.checkout_body
  if checkout_body == blank
    assign checkout_body = 'hero.checkout_body' | t
  endif

  assign hero_image_alt = section.settings.image_alt
  if hero_image_alt == blank
    assign hero_image_alt = 'home.hero.image_alt' | t
  endif
-%}

<section class="hero-apple" aria-labelledby="HeroHeading">
  <div class="hero-apple__glow" aria-hidden="true"></div>
  <div class="hero-apple__grain" aria-hidden="true"></div>

  <div class="hero-apple__content">
    <div class="hero-apple__text">
      <p class="overline-blue-dark">{%- if section.settings.eyebrow != blank -%}{{ section.settings.eyebrow }}{%- else -%}{{ 'home.hero.eyebrow' | t }}{%- endif -%}</p>

      <h1 class="headline-hero hero-apple__headline" id="HeroHeading">
        {%- if section.settings.headline != blank -%}{{ section.settings.headline | escape }}{%- else -%}{{ 'home.hero.headline' | t | escape }}{%- endif -%}
      </h1>

      <p class="body-elevated hero-apple__sub">{%- if section.settings.lede != blank -%}{{ section.settings.lede }}{%- else -%}{{ 'home.hero.lede' | t }}{%- endif -%}</p>

      <div class="hero-apple__ctas">
        <a href="{{ cta_primary_url }}" class="btn-apple-blue">
          {%- if section.settings.cta_primary_label != blank -%}{{ section.settings.cta_primary_label }}{%- else -%}{{ 'home.hero.cta_primary_label' | t }}{%- endif -%}
        </a>
        <a href="{{ section.settings.cta_secondary_url | default: '#how-it-works' }}" class="link-apple-blue">
          {%- if section.settings.cta_secondary_label != blank -%}{{ section.settings.cta_secondary_label }}{%- else -%}{{ 'home.hero.cta_secondary_label' | t }}{%- endif -%}
          <svg width="7" height="12" viewBox="0 0 7 12" fill="none" aria-hidden="true">
            <path d="M1 1L6 6L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-apple__product">
      {%- if hero_image -%}
        <img
          src="{{ hero_image | image_url: width: 1200 }}"
          alt="{{ hero_image.alt | default: hero_image_alt | escape }}"
          width="{{ hero_image.width }}"
          height="{{ hero_image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <img
          src="{{ hero_image_url }}"
          alt="{%- if section.settings.image_alt != blank -%}{{ section.settings.image_alt | escape }}{%- else -%}{{ 'home.hero.image_alt' | t | escape }}{%- endif -%}"
          loading="eager"
          fetchpriority="high"
          width="800"
          height="1000"
        >
      {%- endif -%}
      <div class="hero-context-cards" aria-label="{%- if section.settings.callouts_aria_label != blank -%}{{ section.settings.callouts_aria_label | escape }}{%- else -%}{{ 'hero.callouts_aria_label' | t | escape }}{%- endif -%}">
        <div class="hero-context-card hero-context-card--primary">
          <span class="hero-context-card__eyebrow">{{ away_eyebrow | escape }}</span>
          <strong>{{ away_title | escape }}</strong>
          <span>{{ away_body | escape }}</span>
        </div>
        <div class="hero-context-card hero-context-card--privacy">
          <span class="hero-context-card__eyebrow">{{ privacy_eyebrow | escape }}</span>
          <strong>{{ privacy_title | escape }}</strong>
          <span>{{ privacy_body | escape }}</span>
        </div>
        <div class="hero-context-card hero-context-card--delivery">
          <span class="hero-context-card__eyebrow">{{ checkout_eyebrow | escape }}</span>
          <strong>{{ checkout_title | escape }}</strong>
          <span>{{ checkout_body | escape }}</span>
        </div>
      </div>
    </div>

    <a href="#problem" class="hero-apple__scroll" aria-label="{{ 'accessibility.scroll_to_content' | t }}">
      <span class="hero-apple__scroll-icon" aria-hidden="true">
        <span class="hero-apple__scroll-dot"></span>
      </span>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Headline"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "headline", "label": "Headline" },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Subheadline"
    },
    { "type": "text", "id": "cta_primary_label", "label": "Primary button" },
    { "type": "url", "id": "cta_primary_url", "label": "Primary link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary link" },
    { "type": "text", "id": "cta_secondary_url", "label": "Secondary link (anchor OK)", "default": "#how-it-works" },
    {
      "type": "header",
      "content": "Product image"
    },
    { "type": "image_picker", "id": "image", "label": "Product image" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Product image alt text"
    },
    {
      "type": "header",
      "content": "Feature callouts"
    },
    {
      "type": "text",
      "id": "callouts_aria_label",
      "label": "Callouts region label (accessibility)"
    },
    {
      "type": "text",
      "id": "away_eyebrow",
      "label": "Callout 1 — category (top-left)"
    },
    {
      "type": "text",
      "id": "away_title",
      "label": "Callout 1 — title"
    },
    {
      "type": "textarea",
      "id": "away_body",
      "label": "Callout 1 — subtext"
    },
    {
      "type": "text",
      "id": "privacy_eyebrow",
      "label": "Callout 2 — category (right)"
    },
    {
      "type": "text",
      "id": "privacy_title",
      "label": "Callout 2 — title"
    },
    {
      "type": "textarea",
      "id": "privacy_body",
      "label": "Callout 2 — subtext"
    },
    {
      "type": "text",
      "id": "checkout_eyebrow",
      "label": "Callout 3 — category (bottom)"
    },
    {
      "type": "text",
      "id": "checkout_title",
      "label": "Callout 3 — title"
    },
    {
      "type": "textarea",
      "id": "checkout_body",
      "label": "Callout 3 — subtext"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}

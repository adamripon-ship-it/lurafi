<section class="section-apple bg-gray">
  <div class="apple-container">
    <p class="overline-blue">{{ 'home.personas.overline' | t: default: section.settings.overline }}</p>
    <h2 class="headline-section text-center" style="margin-bottom:16px">{{ 'home.personas.heading' | t: default: section.settings.heading }}</h2>
    <p class="body-elevated text-muted text-center" style="max-width:600px;margin:0 auto 64px">{{ 'home.personas.subheading' | t: default: section.settings.subheading }}</p>
    <div class="tile-grid-3">
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{{ 'home.personas.persona_1_title' | t: default: section.settings.persona_1_title }}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{{ 'home.personas.persona_1_body' | t: default: section.settings.persona_1_body }}</p><p style="font-size:14px;color:var(--apple-blue)">{{ 'home.personas.persona_1_quote' | t: default: section.settings.persona_1_quote }}</p></div>
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{{ 'home.personas.persona_2_title' | t: default: section.settings.persona_2_title }}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{{ 'home.personas.persona_2_body' | t: default: section.settings.persona_2_body }}</p><p style="font-size:14px;color:var(--apple-blue)">{{ 'home.personas.persona_2_quote' | t: default: section.settings.persona_2_quote }}</p></div>
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{{ 'home.personas.persona_3_title' | t: default: section.settings.persona_3_title }}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{{ 'home.personas.persona_3_body' | t: default: section.settings.persona_3_body }}</p><p style="font-size:14px;color:var(--apple-blue)">{{ 'home.personas.persona_3_quote' | t: default: section.settings.persona_3_quote }}</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Personas",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "Made for You" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Protection that fits your life." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Whether you travel for work, already have an alarm, or protect a second home—Kevin adapts to how you live." },
    { "type": "text", "id": "persona_1_title", "label": "Persona 1 title", "default": "The Frequent Traveler" },
    { "type": "textarea", "id": "persona_1_body", "label": "Persona 1 body", "default": "You are away more than you are home. Kevin makes sure it never looks that way." },
    { "type": "text", "id": "persona_1_quote", "label": "Persona 1 quote", "default": "\"I travel 200 days a year. Kevin is the one thing that lets me leave without worry.\"" },
    { "type": "text", "id": "persona_2_title", "label": "Persona 2 title", "default": "Already Have an Alarm?" },
    { "type": "textarea", "id": "persona_2_body", "label": "Persona 2 body", "default": "Alarms alert you after trouble starts. Kevin adds believable presence so many break-ins never begin." },
    { "type": "text", "id": "persona_2_quote", "label": "Persona 2 quote", "default": "\"Our alarm stays. Kevin is what makes the house look occupied from the street.\"" },
    { "type": "text", "id": "persona_3_title", "label": "Persona 3 title", "default": "The Second Home Owner" },
    { "type": "textarea", "id": "persona_3_body", "label": "Persona 3 body", "default": "Kevin keeps your property looking lived-in year-round—one app, every address." },
    { "type": "text", "id": "persona_3_quote", "label": "Persona 3 quote", "default": "\"Our chalet stays protected 365 days. No caretaker needed.\"" }
  ],
  "presets": [{ "name": "Personas" }]
}
{% endschema %}

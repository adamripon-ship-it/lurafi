<section class="section-apple bg-gray">
  <div class="apple-container">
    <p class="overline-blue">{%- if section.settings.overline != blank -%}{{ section.settings.overline }}{%- else -%}{{ 'home.personas.overline' | t }}{%- endif -%}</p>
    <h2 class="headline-section text-center" style="margin-bottom:16px">{%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- else -%}{{ 'home.personas.heading' | t }}{%- endif -%}</h2>
    <p class="body-elevated text-muted text-center" style="max-width:600px;margin:0 auto 64px">{%- if section.settings.subheading != blank -%}{{ section.settings.subheading }}{%- else -%}{{ 'home.personas.subheading' | t }}{%- endif -%}</p>
    <div class="tile-grid-3">
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.persona_1_title != blank -%}{{ section.settings.persona_1_title }}{%- else -%}{{ 'home.personas.persona_1_title' | t }}{%- endif -%}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{%- if section.settings.persona_1_body != blank -%}{{ section.settings.persona_1_body }}{%- else -%}{{ 'home.personas.persona_1_body' | t }}{%- endif -%}</p><p style="font-size:14px;color:var(--apple-blue)">{%- if section.settings.persona_1_quote != blank -%}{{ section.settings.persona_1_quote }}{%- else -%}{{ 'home.personas.persona_1_quote' | t }}{%- endif -%}</p></div>
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.persona_2_title != blank -%}{{ section.settings.persona_2_title }}{%- else -%}{{ 'home.personas.persona_2_title' | t }}{%- endif -%}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{%- if section.settings.persona_2_body != blank -%}{{ section.settings.persona_2_body }}{%- else -%}{{ 'home.personas.persona_2_body' | t }}{%- endif -%}</p><p style="font-size:14px;color:var(--apple-blue)">{%- if section.settings.persona_2_quote != blank -%}{{ section.settings.persona_2_quote }}{%- else -%}{{ 'home.personas.persona_2_quote' | t }}{%- endif -%}</p></div>
      <div class="tile tile--white"><h3 style="font-size:21px;font-weight:600;margin-bottom:8px">{%- if section.settings.persona_3_title != blank -%}{{ section.settings.persona_3_title }}{%- else -%}{{ 'home.personas.persona_3_title' | t }}{%- endif -%}</h3><p class="body-standard text-muted" style="margin-bottom:16px">{%- if section.settings.persona_3_body != blank -%}{{ section.settings.persona_3_body }}{%- else -%}{{ 'home.personas.persona_3_body' | t }}{%- endif -%}</p><p style="font-size:14px;color:var(--apple-blue)">{%- if section.settings.persona_3_quote != blank -%}{{ section.settings.persona_3_quote }}{%- else -%}{{ 'home.personas.persona_3_quote' | t }}{%- endif -%}</p></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Personas",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline", "default": "" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "" },
    { "type": "text", "id": "persona_1_title", "label": "Persona 1 title", "default": "" },
    { "type": "textarea", "id": "persona_1_body", "label": "Persona 1 body", "default": "" },
    { "type": "text", "id": "persona_1_quote", "label": "Persona 1 quote", "default": "" },
    { "type": "text", "id": "persona_2_title", "label": "Persona 2 title", "default": "" },
    { "type": "textarea", "id": "persona_2_body", "label": "Persona 2 body", "default": "" },
    { "type": "text", "id": "persona_2_quote", "label": "Persona 2 quote", "default": "" },
    { "type": "text", "id": "persona_3_title", "label": "Persona 3 title", "default": "" },
    { "type": "textarea", "id": "persona_3_body", "label": "Persona 3 body", "default": "" },
    { "type": "text", "id": "persona_3_quote", "label": "Persona 3 quote", "default": "" }
  ],
  "presets": [{ "name": "Personas" }]
}
{% endschema %}

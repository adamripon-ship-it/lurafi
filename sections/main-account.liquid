{%- liquid
  assign welcome_name = customer.first_name | default: customer.email
-%}
<div class="page-width account">
  <header class="account__header">
    <h1>{{ 'customers.account.title' | t }}</h1>
    <p>{{ 'customers.account.welcome' | t: name: welcome_name }}</p>
    <nav class="account__nav">
      <a href="{{ routes.account_addresses_url }}">{{ 'customers.account.addresses' | t: count: customer.addresses_count }}</a>
      <a href="{{ routes.account_logout_url }}">{{ 'customers.account.log_out' | t }}</a>
    </nav>
  </header>

  <section class="account__orders">
    <h2>{{ 'customers.account.orders_title' | t }}</h2>

    {%- if customer.orders.size > 0 -%}
      {%- paginate customer.orders by 20 -%}
        <table class="orders">
          <thead>
            <tr>
              <th>{{ 'customers.account.col_order' | t }}</th>
              <th>{{ 'customers.account.col_date' | t }}</th>
              <th>{{ 'customers.account.col_payment' | t }}</th>
              <th>{{ 'customers.account.col_fulfillment' | t }}</th>
              <th>{{ 'customers.account.col_total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td data-label="{{ 'customers.account.col_order' | t }}"><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td data-label="{{ 'customers.account.col_date' | t }}">{{ order.created_at | date: format: 'on_date' }}</td>
                <td data-label="{{ 'customers.account.col_payment' | t }}">{{ order.financial_status_label }}</td>
                <td data-label="{{ 'customers.account.col_fulfillment' | t }}">{{ order.fulfillment_status_label }}</td>
                <td data-label="{{ 'customers.account.col_total' | t }}">{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" role="navigation">{{ paginate | default_pagination }}</nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p>{{ 'customers.account.no_orders' | t }}</p>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "Account",
  "settings": []
}
{% endschema %}

<div class="page-width account">
  <header class="account__header">
    <h1>My account</h1>
    <p>Welcome back, {{ customer.first_name | default: customer.email }}.</p>
    <nav class="account__nav">
      <a href="{{ routes.account_addresses_url }}">View addresses ({{ customer.addresses_count }})</a>
      <a href="{{ routes.account_logout_url }}">Log out</a>
    </nav>
  </header>

  <section class="account__orders">
    <h2>Order history</h2>

    {%- if customer.orders.size > 0 -%}
      {%- paginate customer.orders by 20 -%}
        <table class="orders">
          <thead>
            <tr>
              <th>Order</th>
              <th>Date</th>
              <th>Payment</th>
              <th>Fulfillment</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: format: 'on_date' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.fulfillment_status_label }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" role="navigation">{{ paginate | default_pagination }}</nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p>You haven&rsquo;t placed any orders yet.</p>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "Account",
  "settings": []
}
{% endschema %}

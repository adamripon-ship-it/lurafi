<div class="page-width collection-page">
  <header class="collection-page__header">
    <p class="eyebrow">Shop</p>
    <h1>Collections</h1>
  </header>

  {%- if collections.size > 0 -%}
    <ul class="product-grid" role="list">
      {%- for collection in collections -%}
        <li class="product-card">
          <a href="{{ collection.url }}" class="product-card__link">
            <div class="product-card__media">
              {%- if collection.featured_image -%}
                <img
                  src="{{ collection.featured_image | image_url: width: 600 }}"
                  alt="{{ collection.featured_image.alt | escape }}"
                  width="{{ collection.featured_image.width }}"
                  height="{{ collection.featured_image.height }}"
                  loading="lazy"
                  class="product-card__img product-card__img--primary"
                >
              {%- else -%}
                <div class="product-card__placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>
            <h3 class="product-card__title">{{ collection.title }}</h3>
            <p class="product-card__price">{{ collection.all_products_count }} product{% if collection.all_products_count != 1 %}s{% endif %}</p>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- else -%}
    <p>No collections yet.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}

{
  "name": "lurafi-theme",
  "version": "2.1.0",
  "private": true,
  "description": "Shopify Online Store 2.0 theme for mitipi.eu (Kevin presence simulator, Mitipi GmbH)",
  "type": "module",
  "scripts": {
    "theme:check": "shopify theme check",
    "theme:push:live": "./scripts/deploy-theme-live.sh",
    "theme:deploy:live": "./scripts/deploy-theme-live.sh",
    "theme:publish:live": "./scripts/publish-theme-live.sh",
    "theme:cache:bust": "node scripts/bust-homepage-page-cache.mjs --verify",
    "theme:verify:live": "node scripts/verify-live-storefront.mjs",
    "locales:build": "node scripts/build-locales.mjs",
    "locales:sync": "node scripts/sync-locale-keys.mjs",
    "locales:translate": "node scripts/translate-locales.mjs",
    "locales:translate:claude": "node scripts/translate-locales.mjs --provider=claude --include-nl",
    "locales:translate:customers": "node scripts/translate-locales.mjs --prefix=customers.,header.",
    "predeploy": "npm run locales:build && npm run locales:sync && npm run geo:generate && npm run assets:audit:ci && npm run theme:check",
    "geo:generate": "node scripts/generate-sitemap-ai.mjs && node scripts/generate-llms-assets.mjs",
    "cms:seed": "node scripts/seed-theme-content.mjs --write --include-blocks",
    "cms:seed:dry": "node scripts/seed-theme-content.mjs",
    "cms:navigation": "node scripts/setup-cms-navigation.mjs",
    "cms:footer-templates": "node scripts/build-footer-page-templates.mjs",
    "cms:footer-pages": "node scripts/sync-footer-pages.mjs",
    "shopify:locales": "./scripts/activate-locales.sh",
    "shopify:markets:countries": "node scripts/setup-market-countries.mjs",
    "shopify:refresh-token": "./scripts/shopify-refresh-admin-token.sh",
    "shopify:sync-github-secrets": "./scripts/sync-github-deploy-secrets.sh",
    "shopify:publish:mitipi": "./scripts/publish-lurafi-live.sh",
    "shopify:products:migrate": "node scripts/migrate-products-productSet.mjs",
    "shopify:commerce:setup": "node scripts/setup-mitipi-commerce.mjs",
    "shopify:provision:pricing": "node scripts/provision-pricing.mjs",
    "shopify:provision:pricing:dry": "node scripts/provision-pricing.mjs --dry-run",
    "shopify:approve-scopes": "./scripts/request-app-scope-approval.sh",
    "qa:full": "LURAFI_URL=https://mitipi.eu node scripts/qa-full.mjs",
    "qa:mitipi": "node scripts/qa-mitipi-report.mjs",
    "qa:mitipi:backend": "node scripts/qa-mitipi-backend.mjs",
    "qa:mitipi:browser": "LURAFI_URL=https://mitipi.eu node scripts/browser-qa.mjs",
    "qa:mitipi:audit": "LURAFI_URL=https://mitipi.eu node scripts/full-site-audit.mjs",
    "qa:i18n": "node scripts/i18n-browser-qa.mjs",
    "qa:language": "LURAFI_URL=https://mitipi.eu node scripts/qa-language-selector.mjs",
    "test:e2e": "playwright test",
    "test:e2e:live": "LURAFI_URL=https://mitipi.eu playwright test",
    "assets:audit": "node scripts/audit-assets.mjs",
    "assets:audit:ci": "node scripts/audit-assets.mjs --ci",
    "cms:metaobjects": "node scripts/setup-metaobjects.mjs",
    "cms:upload-assets": "node scripts/upload-assets.mjs",
    "cms:provision": "node scripts/provision-cms.mjs --apply",
    "cms:provision:dry": "node scripts/provision-cms.mjs",
    "i18n:audit": "node scripts/audit-translations.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@shopify/cli": "^3.84.0",
    "playwright": "^1.52.0"
  },
  "engines": {
    "node": ">=20"
  }
}

# Copy to .env for local-only secrets (never commit .env)

# --- Migration / deploy ---
# NEW store (target production)
SHOPIFY_STORE=your-new-store.myshopify.com
OLD_SHOPIFY_STORE=fu03cn-1v.myshopify.com

# Optional: override theme push target
# SHOPIFY_THEME_ID=

# --- Cloudflare (optional — DNS automation / verification) ---
# Create token: Zone → DNS → Edit, zone lurafi.com only
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# --- GitHub (optional fallback for scripts) ---
# GITHUB_TOKEN=github_pat_...

# --- Shopify Admin (recommended for mitipi-2 — skips browser OAuth) ---
# Dev Dashboard → lurafi → Settings → App automation token, or custom app shpat_
# SHOPIFY_ADMIN_TOKEN=
# SHOPIFY_THEME_PASSWORD=   # optional alias; same value as SHOPIFY_ADMIN_TOKEN for theme push
# SHOPIFY_THEME_NAME=lurafi-deploy   # unpublished theme name for migrate-to-store.sh

# --- Translations (optional) ---
# DEEPL_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Other ---
# VERCEL_TOKEN=

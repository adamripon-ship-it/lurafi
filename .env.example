# Copy to .env for local-only secrets (never commit .env)

# --- Migration / deploy ---
# NEW store (target production)
SHOPIFY_STORE=your-new-store.myshopify.com
OLD_SHOPIFY_STORE=fu03cn-1v.myshopify.com

# Optional: override theme push target
# SHOPIFY_THEME_ID=

# --- Cloudflare (optional — DNS automation / verification) ---
# Create token: Zone → DNS → Edit, zone lurafi.com only
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# --- GitHub (optional fallback for scripts) ---
# GITHUB_TOKEN=github_pat_...

# --- Shopify Admin (optional fallback if CLI session missing) ---
# SHOPIFY_ADMIN_TOKEN=

# --- Translations (optional) ---
# DEEPL_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Other ---
# VERCEL_TOKEN=

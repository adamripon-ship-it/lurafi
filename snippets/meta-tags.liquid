{%- liquid
  assign lurafi_published_locale_csv = ',en,nl,fr,de,cs,'
  assign lurafi_default_image = 'https://d2xsxph8kpxj0f.cloudfront.net/310519663143838195/XAqmtb4V6fmS5cL6eq54xv/lurafi-device-angle-transparent-feBmUBJ5mWe9dTyXfTHnUU.webp'
  assign lurafi_meta_description = page_description
  assign lurafi_canonical_url = seo_canonical_url | default: canonical_url
  assign llms_page_url = pages.llms.url
  assign lurafi_meta_title = page_title

  if request.page_type == 'index'
    assign lurafi_meta_title = 'seo.home.title' | t | default: page_title
  endif

  if lurafi_meta_description == blank and request.page_type == 'index'
    assign lurafi_meta_description = 'seo.home.description' | t
  endif

  if request.page_type == 'page'
    case page.handle
      when 'sitemap'
        if lurafi_meta_description == blank
          assign lurafi_meta_description = 'seo.sitemap.description' | t
        endif
        if page.title == blank or page.title == shop.name
          assign lurafi_meta_title = 'seo.sitemap.title' | t
        endif
      when 'llms', 'ai-overzicht', 'apercu-ia', 'ki-uebersicht', 'resumen-ia', 'panoramica-ia', 'ai-oversikt', 'ai-oversigt', 'ai-yhteenveto', 'ai-prehled', 'podsumowanie-ai'
        if lurafi_meta_description == blank
          assign lurafi_meta_description = 'seo.llms.description' | t
        endif
        if page.title == blank or page.title == shop.name
          assign lurafi_meta_title = 'seo.llms.title' | t
        endif
    endcase
  endif

  assign locale_root = request.locale.iso_code | split: '-' | first | downcase
  assign og_locale = 'en_US'
  case locale_root
    when 'nl'
      assign og_locale = 'nl_NL'
    when 'fr'
      assign og_locale = 'fr_FR'
    when 'de'
      assign og_locale = 'de_DE'
    when 'cs'
      assign og_locale = 'cs_CZ'
  endcase

  assign lurafi_og_image = page_image
  if lurafi_og_image == blank and settings.default_share_image != blank
    assign lurafi_og_image = settings.default_share_image
  endif
  if lurafi_og_image == blank and settings.favicon != blank
    assign lurafi_og_image = settings.favicon
  endif
-%}
{%- if lurafi_meta_description != blank -%}
  <meta name="description" content="{{ lurafi_meta_description | escape }}">
{%- endif -%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:locale" content="{{ og_locale }}">
{%- for language in localization.available_languages -%}
  {%- assign alt_lang_root = language.iso_code | split: '-' | first | downcase -%}
  {%- assign alt_lang_token = ',' | append: alt_lang_root | append: ',' -%}
  {%- if lurafi_published_locale_csv contains alt_lang_token -%}
  {%- unless language.iso_code == request.locale.iso_code -%}
    {%- assign alt_root = language.iso_code | split: '-' | first | downcase -%}
    {%- assign alt_og = 'en_US' -%}
    {%- case alt_root -%}
      {%- when 'nl' -%}{%- assign alt_og = 'nl_NL' -%}
      {%- when 'fr' -%}{%- assign alt_og = 'fr_FR' -%}
      {%- when 'de' -%}{%- assign alt_og = 'de_DE' -%}
      {%- when 'cs' -%}{%- assign alt_og = 'cs_CZ' -%}
    {%- endcase -%}
    <meta property="og:locale:alternate" content="{{ alt_og }}">
  {%- endunless -%}
  {%- endif -%}
{%- endfor -%}
<meta property="og:url" content="{{ lurafi_canonical_url }}">
<meta property="og:title" content="{{ lurafi_meta_title | escape }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">
<meta property="og:description" content="{{ lurafi_meta_description | default: shop.description | default: shop.name | escape }}">

{%- if lurafi_og_image -%}
  <meta property="og:image" content="https:{{ lurafi_og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ lurafi_og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ lurafi_og_image.height | default: 630 }}">
  <meta property="og:image:alt" content="{{ lurafi_meta_title | escape }}">
  <meta name="twitter:image" content="https:{{ lurafi_og_image | image_url: width: 1200 }}">
{%- elsif request.page_type == 'index' -%}
  <meta property="og:image" content="{{ lurafi_default_image }}">
  <meta property="og:image:secure_url" content="{{ lurafi_default_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="1500">
  <meta property="og:image:alt" content="{{ 'home.hero.image_alt' | t | escape }}">
  <meta name="twitter:image" content="{{ lurafi_default_image }}">
{%- endif -%}

{%- if llms_page_url != blank -%}
<link rel="alternate" type="text/plain" href="{{ llms_page_url }}" title="LLM site summary">
{%- endif -%}
<link rel="alternate" type="text/plain" href="{{ 'llms.txt' | asset_url }}" title="Short LLM summary (llms.txt)" hreflang="en">
<link rel="alternate" type="text/plain" href="{{ 'llms-full.txt' | asset_url }}" title="Full LLM summary (llms-full.txt)" hreflang="en">
<meta name="ai:short-summary" content="{{ 'llms.txt' | asset_url | prepend: 'https:' }}">
<meta name="ai:full-summary" content="{{ 'llms-full.txt' | asset_url | prepend: 'https:' }}">
{%- comment -%} GEO knowledge files (Markdown) — structured facts for AI/LLM ingestion {%- endcomment -%}
<link rel="alternate" type="text/markdown" href="{{ 'kevin.md' | asset_url }}" title="Kevin knowledge index (Markdown)">
<link rel="alternate" type="text/markdown" href="{{ 'kevin-product.md' | asset_url }}" title="Kevin product overview (Markdown)">
<link rel="alternate" type="text/markdown" href="{{ 'kevin-specs.md' | asset_url }}" title="Kevin specifications (Markdown)">
<link rel="alternate" type="text/markdown" href="{{ 'kevin-faq.md' | asset_url }}" title="Kevin FAQ (Markdown)">
<link rel="alternate" type="text/markdown" href="{{ 'kevin-company.md' | asset_url }}" title="About Mitipi (Markdown)">
<meta name="ai:knowledge-index" content="{{ 'kevin.md' | asset_url | prepend: 'https:' }}">
{%- comment -%} Localized LLM summaries — only the published storefront locales {%- endcomment -%}
{%- assign llm_locales = 'nl,fr,de,cs' | split: ',' -%}
{%- for llm_code in llm_locales -%}
  {%- assign short_asset = 'llms.' | append: llm_code | append: '.txt' -%}
  {%- assign full_asset = 'llms-full.' | append: llm_code | append: '.txt' -%}
  <link rel="alternate" type="text/plain" href="{{ short_asset | asset_url }}" title="Short LLM summary ({{ llm_code | upcase }})" hreflang="{{ llm_code }}">
  <link rel="alternate" type="text/plain" href="{{ full_asset | asset_url }}" title="Full LLM summary ({{ llm_code | upcase }})" hreflang="{{ llm_code }}">
{%- endfor -%}
<link rel="sitemap" type="application/xml" href="{{ 'sitemap-ai.xml' | asset_url }}" title="AI sitemap">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ lurafi_meta_title | escape }}">
<meta name="twitter:description" content="{{ lurafi_meta_description | default: shop.description | default: shop.name | escape }}">

{%- comment -%}
  Curved sound-wave ripples emanating from Kevin — full hero, behind product.
  Visible when .hero-apple--product-active (hero-slider.js).
{%- endcomment -%}
{%- assign beam_uid = section.id | default: 'hero' -%}
<div class="hero-apple__beams" aria-hidden="true">
  <svg
    class="hero-apple__beams-svg"
    viewBox="0 0 1440 820"
    preserveAspectRatio="xMidYMid meet"
    focusable="false"
  >
    <defs>
      <filter id="hero-wave-blue-{{ beam_uid }}" x="-50%" y="-50%" width="200%" height="200%" color-interpolation-filters="sRGB">
        <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <filter id="hero-wave-pink-{{ beam_uid }}" x="-50%" y="-50%" width="200%" height="200%" color-interpolation-filters="sRGB">
        <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <radialGradient id="hero-wave-origin-{{ beam_uid }}" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#c868e0" stop-opacity="0.45"/>
        <stop offset="55%" stop-color="#8040b8" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="#8040b8" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <ellipse
      class="hero-apple__wave-origin"
      cx="720"
      cy="548"
      rx="90"
      ry="36"
      fill="url(#hero-wave-origin-{{ beam_uid }})"
    />

    {%- comment -%} Blue sound waves — small wavy curves, product → lower-left {%- endcomment -%}
    <g class="hero-apple__sound-waves hero-apple__sound-waves--blue" filter="url(#hero-wave-blue-{{ beam_uid }})">
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--blue hero-apple__wave--1"
        d="M 714 544 C 706 540, 698 548, 690 544 C 682 540, 674 548, 666 544"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--blue hero-apple__wave--2"
        d="M 714 546 C 702 538, 690 552, 676 544 C 662 536, 646 550, 630 542 C 614 534, 596 548, 578 540"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--blue hero-apple__wave--3"
        d="M 714 548 C 696 532, 678 556, 656 540 C 634 524, 610 552, 584 536 C 558 520, 528 548, 496 532"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--blue hero-apple__wave--4"
        d="M 714 550 C 688 526, 662 558, 632 530 C 602 502, 568 548, 532 518 C 496 488, 448 538, 392 508 C 340 480, 280 540, 200 510"
      />
    </g>

    {%- comment -%} Pink sound waves — mirror, product → lower-right {%- endcomment -%}
    <g class="hero-apple__sound-waves hero-apple__sound-waves--pink" filter="url(#hero-wave-pink-{{ beam_uid }})">
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--pink hero-apple__wave--1"
        d="M 726 544 C 734 540, 742 548, 750 544 C 758 540, 766 548, 774 544"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--pink hero-apple__wave--2"
        d="M 726 546 C 738 538, 750 552, 764 544 C 778 536, 794 550, 810 542 C 826 534, 844 548, 862 540"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--pink hero-apple__wave--3"
        d="M 726 548 C 744 532, 762 556, 784 540 C 806 524, 830 552, 856 536 C 882 520, 912 548, 944 532"
      />
      <path
        pathLength="1"
        class="hero-apple__wave hero-apple__wave--pink hero-apple__wave--4"
        d="M 726 550 C 752 526, 778 558, 808 530 C 838 502, 872 548, 908 518 C 944 488, 992 538, 1048 508 C 1100 480, 1160 540, 1240 510"
      />
    </g>
  </svg>
</div>

{%- comment -%}
  Renders one app showcase phone slide.

  Accepts:
  - image: {Image}
  - fallback_url: {string}
  - alt: {string}
  - caption: {string}
  - tilt_class: {string}
{%- endcomment -%}

<figure class="app-showcase__phone {{ tilt_class }}" data-lp-app-slide>
  <div class="app-showcase__frame">
    {%- if image != blank -%}
      <img
        class="app-showcase__image"
        src="{{ image | image_url: width: 720 }}"
        srcset="
          {{ image | image_url: width: 360 }} 360w,
          {{ image | image_url: width: 480 }} 480w,
          {{ image | image_url: width: 640 }} 640w,
          {{ image | image_url: width: 720 }} 720w
        "
        sizes="(min-width: 768px) 22vw, 78vw"
        alt="{{ image.alt | default: alt | escape }}"
        width="{{ image.width | default: 473 }}"
        height="{{ image.height | default: 1024 }}"
        loading="lazy"
      >
    {%- else -%}
      <img
        class="app-showcase__image"
        src="{{ fallback_url }}"
        alt="{{ alt | escape }}"
        width="473"
        height="1024"
        loading="lazy"
      >
    {%- endif -%}
  </div>
  {%- if caption != blank -%}
    <figcaption class="app-showcase__caption">{{ caption }}</figcaption>
  {%- endif -%}
</figure>

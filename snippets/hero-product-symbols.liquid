{%- comment -%}
  Decorative minimal icons around the Kevin product rotator — sound, activities, AI.
  Purely visual; rotator aria-label carries accessibility.
{%- endcomment -%}
<div class="hero-product-symbols" aria-hidden="true">
  <span class="hero-product-symbol hero-product-symbol--sound-waves" style="--symbol-delay: 0s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" aria-hidden="true">
      <path d="M4 9v6"/>
      <path d="M8 6v12"/>
      <path d="M12 8v8"/>
      <path d="M16 5v14"/>
      <path d="M20 9v6"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--music" style="--symbol-delay: 0.4s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M14 4l6 2v8"/>
      <circle cx="8" cy="18" r="3"/>
      <circle cx="17" cy="16" r="3"/>
      <path d="M14 4v12"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--cleaning" style="--symbol-delay: 0.8s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 20l4-10"/>
      <path d="M10 10l8-2"/>
      <path d="M18 8l-2 6"/>
      <path d="M5 21h6"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--cooking" style="--symbol-delay: 1.1s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 11h16"/>
      <path d="M6 11v2a6 6 0 0 0 12 0v-2"/>
      <path d="M8 7h.01M12 7h.01M16 7h.01"/>
      <path d="M9 4h6"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--discussion" style="--symbol-delay: 0.2s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M7 9h6a3 3 0 0 1 0 6H9l-3 3V9z"/>
      <path d="M13 7h5a2 2 0 0 1 0 4h-3l-2 2V7z"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--games" style="--symbol-delay: 0.6s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 12h4"/>
      <path d="M8 10v4"/>
      <circle cx="15" cy="11" r="1" fill="currentColor" stroke="none"/>
      <circle cx="18" cy="13" r="1" fill="currentColor" stroke="none"/>
      <path d="M4 8h16a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2z"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--tv" style="--symbol-delay: 1.4s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="12" rx="1.5"/>
      <path d="M8 21h8"/>
      <path d="M12 17v4"/>
      <path d="M9 9h6"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--ai" style="--symbol-delay: 0.3s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3l1.2 3.6L17 7.8l-3.6 1.2L12 12.6 10.6 9l-3.6-1.2 3.6-1.2L12 3z"/>
      <circle cx="6" cy="17" r="1.5" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="19" r="1.5" fill="currentColor" stroke="none"/>
      <circle cx="18" cy="17" r="1.5" fill="currentColor" stroke="none"/>
      <path d="M7.5 17h3M13.5 17h3M9 17v2M15 17v2"/>
    </svg>
  </span>

  <span class="hero-product-symbol hero-product-symbol--sound-waves hero-product-symbol--sound-waves-alt" style="--symbol-delay: 0.9s">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" aria-hidden="true">
      <path d="M5 10v4"/>
      <path d="M9 7v10"/>
      <path d="M13 10v4"/>
      <path d="M17 8v8"/>
    </svg>
  </span>
</div>

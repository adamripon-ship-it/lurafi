{%- comment -%}
  One optional front-cover add-on with a quantity stepper (any colour, any volume).
  Params: cover_name, default_name, cover_variant (Shopify variant id),
  cover_image (image_picker or blank), default_img (CDN url), price_label.
  A cover is purchasable only when cover_variant is set; otherwise it shows "Soon".
  Live cover product: kevin-front-cover (4 Colour variants, 31.50 EUR / 29.00 CHF).
{%- endcomment -%}
{%- liquid
  assign cover_label = cover_name | default: default_name
  if cover_image != blank
    assign img_src = cover_image | image_url: width: 220
  else
    assign img_src = default_img | append: '&width=220'
  endif
  assign is_soon = false
  if cover_variant == blank
    assign is_soon = true
  endif
-%}
<div class="configure-cover{% if is_soon %} is-soon{% endif %}" data-cover data-cover-id="{{ cover_variant }}" data-cover-price="{{ price_cents | default: 0 }}"{% if is_soon %} data-cover-soon="1"{% endif %}>
  <span class="configure-cover__img"><img src="{{ img_src }}" alt="{{ 'configure.cover_alt' | t: name: cover_label | escape }}" loading="lazy" width="80" height="80"></span>
  <span class="configure-cover__name">{{ cover_label | escape }}</span>
  {%- if is_soon -%}
    <span class="configure-cover__price">{{ 'configure.cover_soon' | t }}</span>
  {%- else -%}
    <span class="configure-cover__price">{{ price_label }}</span>
    <div class="configure-cover__qty" role="group" aria-label="{{ 'configure.cover_qty_label' | t: name: cover_label | escape }}">
      <button type="button" class="configure-cover__qty-btn" data-cover-minus aria-label="{{ 'configure.cover_minus_label' | t: name: cover_label | escape }}">&minus;</button>
      <span class="configure-cover__qty-val" data-cover-qty aria-live="polite">0</span>
      <button type="button" class="configure-cover__qty-btn" data-cover-plus aria-label="{{ 'configure.cover_plus_label' | t: name: cover_label | escape }}">+</button>
    </div>
  {%- endif -%}
</div>

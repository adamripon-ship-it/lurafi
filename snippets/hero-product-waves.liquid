{%- comment -%}
  ECG / heart-monitor sound lines from product center — left and right, full bleed.
  Rendered inside hero-product-stage so origin tracks the rotator on all viewports.
{%- endcomment -%}
{%- assign wave_uid = block_id | default: section.id | default: 'hero' -%}

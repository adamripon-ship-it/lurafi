      <filter id="hero-ecg-glow-{{ wave_uid }}" x="-80%" y="-400%" width="260%" height="900%" color-interpolation-filters="sRGB">
        <feGaussianBlur in="SourceGraphic" stdDeviation="3.5" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
    <g class="hero-product-waves__origin" transform="translate(1200, 50)" filter="url(#hero-ecg-glow-{{ wave_uid }})">

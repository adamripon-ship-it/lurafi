{%- comment -%}
  Language + country (Markets) switcher via POST /localization.
  @param form_id {String}
  @param selector_id {String}
  @param country_selector_id {String}
{%- endcomment -%}
{%- liquid
  comment
    LURAFI_PUBLISHED_LOCALES — updated by npm run locales:build
  endcomment
  assign lurafi_published_locale_csv = ',en,nl,fr,de,cs,'
  assign lurafi_published_country_csv = ',DE,FR,IE,NL,CZ,'
  assign form_id = form_id | default: 'LocalizationForm'
  assign selector_id = selector_id | default: 'LanguageSelector'
  assign country_selector_id = country_selector_id | default: 'CountrySelector'
  assign published_country_count = 0
  for country in localization.available_countries
    assign country_token = ',' | append: country.iso_code | append: ','
    if lurafi_published_country_csv contains country_token
      assign published_country_count = published_country_count | plus: 1
    endif
  endfor
  assign show_country = false
  if published_country_count > 1
    assign show_country = true
  endif
  assign published_language_count = 0
  for language in localization.available_languages
    assign lang_root = language.iso_code | split: '-' | first | downcase
    assign lang_token = ',' | append: lang_root | append: ','
    if lurafi_published_locale_csv contains lang_token
      assign published_language_count = published_language_count | plus: 1
    endif
  endfor
  assign show_language = false
  if published_language_count > 1
    assign show_language = true
  endif

  assign return_to = request.path | default: '/'
  if return_to == blank
    assign return_to = '/'
  endif
  if request.search != blank
    assign return_to = return_to | append: request.search
  elsif request.query_string != blank
    assign return_to = return_to | append: '?' | append: request.query_string
  endif
-%}
{%- if show_country or show_language -%}
  <!-- lurafi-lang-filter-v3 -->
  <div class="language-selector" data-language-selector>
    <form
      method="post"
      action="/localization"
      id="{{ form_id }}"
      class="language-selector__form"
      accept-charset="UTF-8"
      enctype="multipart/form-data"
    >
      <input type="hidden" name="form_type" value="localization">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="_method" value="put">
      <input
        type="hidden"
        name="return_to"
        value="{{ return_to | escape }}"
        data-language-return-to
      >

      {%- if show_country -%}
        <label class="language-selector__label visually-hidden" for="{{ country_selector_id }}">
          {{ 'country.label' | t: default: 'Country' }}
        </label>
        <select
          id="{{ country_selector_id }}"
          name="country_code"
          class="language-selector__select language-selector__select--country"
          aria-label="{{ 'country.label' | t: default: 'Country' }}"
          data-country-select
          autocomplete="country"
        >
          {%- for country in localization.available_countries -%}
            {%- assign country_token = ',' | append: country.iso_code | append: ',' -%}
            {%- if lurafi_published_country_csv contains country_token -%}
              <option
                value="{{ country.iso_code }}"
                {% if country.iso_code == localization.country.iso_code %}
                  selected
                {% endif %}
              >
                {{ country.name }} ({{ country.currency.iso_code }})
              </option>
            {%- endif -%}
          {%- endfor -%}
        </select>
      {%- endif -%}

      {%- if show_language -%}
        <label class="language-selector__label visually-hidden" for="{{ selector_id }}">
          {{ 'language.label' | t }}
        </label>
        <select
          id="{{ selector_id }}"
          name="locale_code"
          class="language-selector__select language-selector__select--language"
          aria-label="{{ 'language.label' | t }}"
          data-language-select
          autocomplete="language"
        >
          {%- for language in localization.available_languages -%}
            {%- assign lang_root = language.iso_code | split: '-' | first | downcase -%}
            {%- assign lang_token = ',' | append: lang_root | append: ',' -%}
            {%- if lurafi_published_locale_csv contains lang_token -%}
              {%- assign lang_key = 'language.' | append: lang_root -%}
              <option
                value="{{ language.iso_code }}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}
                  selected
                {% endif %}
              >
                {{ lang_key | t: default: language.endonym_name }}
              </option>
            {%- endif -%}
          {%- endfor -%}
        </select>
      {%- endif -%}

      <noscript>
        <button type="submit" class="language-selector__noscript-btn">{{ 'language.label' | t }}</button>
      </noscript>
    </form>
  </div>
  <script>
    (function () {
      var form = document.getElementById({{ form_id | json }});
      if (!form) return;
      var langSelect = form.querySelector('[data-language-select]');
      var countrySelect = form.querySelector('[data-country-select]');
      function syncReturnTo() {
        var input = form.querySelector('[data-language-return-to]');
        if (input) {
          input.value = (window.location.pathname || '/') + (window.location.search || '');
        }
      }
      form.addEventListener('submit', syncReturnTo);
      function submitLocalization(source) {
        syncReturnTo();
        if (form.requestSubmit) form.requestSubmit();
        else form.submit();
      }
      if (langSelect) {
        langSelect.addEventListener('change', function () { submitLocalization('language'); });
      }
      if (countrySelect) {
        countrySelect.addEventListener('change', function () { submitLocalization('country'); });
      }
      syncReturnTo();
    })();
  </script>
{%- endif -%}

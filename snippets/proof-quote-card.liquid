{%- comment -%}
  Testimonial quote card.
  @param quote {String}
  @param author_name {String}
  @param author_location {String}
{%- endcomment -%}
{%- liquid
  # Metaobject-authored values: decode common entities before | escape so a
  # pre-encoded stored value cannot double-escape into visible &#39; / &amp;
  # (same decode-guard pattern as snippets/section-intro.liquid).
  assign proof_quote = quote | strip | remove: '"' | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"' | escape
  assign proof_name = author_name | strip | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"' | escape
  assign name_parts = proof_name | split: ' '
  assign proof_initial_1 = name_parts[0] | slice: 0, 1
  assign proof_initial_2 = ''
  if name_parts.size > 1
    assign proof_initial_2 = name_parts[1] | slice: 0, 1
  endif
  assign proof_initials = proof_initial_1 | append: proof_initial_2 | upcase
  assign proof_location = author_location | strip | replace: '&amp;', '&' | replace: '&#39;', "'" | replace: '&#x27;', "'" | replace: '&quot;', '"' | replace: '&#34;', '"' | escape
-%}
<article class="{{ card_class | default: 'proof-quote-card tile tile--white' }}"{{ block_attributes }}>
  <span class="proof-quote-card__mark" aria-hidden="true">"</span>
  <blockquote class="proof-quote-card__quote">
    <p>{{ proof_quote }}</p>
  </blockquote>
  <footer class="proof-quote-card__author">
    <span class="proof-quote-card__avatar" aria-hidden="true">{{ proof_initials }}</span>
    <span class="proof-quote-card__meta">
      <cite class="proof-quote-card__name">{{ proof_name }}</cite>
      <span class="proof-quote-card__location">{{ proof_location }}</span>
    </span>
  </footer>
</article>

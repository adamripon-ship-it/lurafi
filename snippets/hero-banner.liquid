{%- comment -%}
  Static full-page product hero.
  Pass: hero_eyebrow, hero_headline, hero_lede, cta_*, image, image_alt,
        callout_*_{eyebrow,title,body}, callouts_aria_label, banner_id
{%- endcomment -%}
{%- liquid
  assign product_image_url = ''
  if image != blank
    assign product_image_url = image | image_url: width: 1200
    assign product_image_alt = image.alt | default: image_alt
  else
    assign product_image_url = 'kevin-hero-product-front.png' | asset_url
    assign product_image_alt = image_alt
  endif
  if product_image_alt == blank
    assign product_image_alt = 'home.hero.image_alt' | t
  endif
-%}

<div class="hero-banner">
  {% render 'hero-banner-copy',
    eyebrow: hero_eyebrow,
    headline: hero_headline,
    lede: hero_lede,
    cta_primary_url: cta_primary_url,
    cta_primary_label: cta_primary_label,
    cta_secondary_url: cta_secondary_url,
    cta_secondary_label: cta_secondary_label
  %}

  <div class="hero-banner__media">
    <div class="hero-banner__visual">
      <div class="hero-banner__visual-glow" aria-hidden="true"></div>
      <div class="hero-banner__product-stage" role="group" aria-label="{{ callouts_aria_label | escape }}">
        {%- if callout_1_title != blank or callout_1_body != blank -%}
          {% render 'hero-banner-callout',
            modifier: 'primary',
            eyebrow: callout_1_eyebrow,
            title: callout_1_title,
            body: callout_1_body
          %}
        {%- endif -%}
        {%- if callout_2_title != blank or callout_2_body != blank -%}
          {% render 'hero-banner-callout',
            modifier: 'privacy',
            eyebrow: callout_2_eyebrow,
            title: callout_2_title,
            body: callout_2_body
          %}
        {%- endif -%}
        {%- if callout_3_title != blank or callout_3_body != blank -%}
          {% render 'hero-banner-callout',
            modifier: 'delivery',
            eyebrow: callout_3_eyebrow,
            title: callout_3_title,
            body: callout_3_body
          %}
        {%- endif -%}
        {%- if callout_4_title != blank or callout_4_body != blank -%}
          {% render 'hero-banner-callout',
            modifier: 'feature',
            eyebrow: callout_4_eyebrow,
            title: callout_4_title,
            body: callout_4_body
          %}
        {%- endif -%}
        <div class="hero-banner__product-cell">
          {% render 'hero-product-waves', block_id: banner_id %}
          <figure class="hero-banner__product">
            <img
              class="hero-banner__product-image"
              src="{{ product_image_url }}"
              alt="{{ product_image_alt | escape }}"
              width="1200"
              height="803"
              loading="eager"
              fetchpriority="high"
            >
          </figure>
        </div>
      </div>
    </div>
  </div>
</div>

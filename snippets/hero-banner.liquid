{%- comment -%}
  Static hero — headline, lede, dual CTAs, product centerpiece (focus v4).
{%- endcomment -%}

<div class="hero-banner" data-hero-layout="focus-v4">
  {% render 'hero-banner-copy',
    headline: hero_headline,
    lede: hero_lede,
    cta_primary_url: cta_primary_url,
    cta_primary_label: cta_primary_label,
    cta_secondary_url: cta_secondary_url,
    cta_secondary_label: cta_secondary_label
  %}

  <div class="hero-banner__product-stage">
    <div class="hero-banner__product-glow" aria-hidden="true">
      <span class="hero-banner__glow-layer hero-banner__glow-layer--purple"></span>
      <span class="hero-banner__glow-layer hero-banner__glow-layer--magenta"></span>
      <span class="hero-banner__glow-layer hero-banner__glow-layer--pink"></span>
    </div>
    <figure class="hero-banner__product">
      {% render 'hero-banner-product-image', image: image, image_alt: image_alt, ambient_video: ambient_video %}
    </figure>
  </div>
</div>

{%- liquid
  if settings.logo != blank
    assign org_logo = settings.logo | image_url: width: 512
  else
    assign org_logo = 'kevin-header-logo.png' | asset_url | prepend: 'https:'
  endif
  assign kevin_image = 'kevin-hero-product-front.webp' | asset_url | prepend: 'https:'
  assign org_description = 'seo.org_description' | t
  assign org_email = 'hello@mitipi.eu'
  assign org_id = shop.url | append: '/#organization'
  assign site_id = shop.url | append: '/#website'
  assign buy_product = settings.product_buy
  capture configure_buy_url
    render 'configure-url', plan: 'buy'
  endcapture
  assign configure_buy_url = configure_buy_url | strip
  assign offer_currency = cart.currency.iso_code | default: shop.currency
  assign offer_price = 649
  if buy_product != blank
    assign offer_price = buy_product.price | divided_by: 100.0
  endif
  assign offer_availability = 'https://schema.org/PreOrder'
  if buy_product != blank and buy_product.available
    assign offer_availability = 'https://schema.org/InStock'
  endif
  assign product_url = shop.url | append: configure_buy_url
  assign product_sku = 'KEVIN'
  if buy_product != blank
    assign product_url = shop.url | append: buy_product.url
    assign product_sku = buy_product.selected_or_first_available_variant.sku | default: product_sku
  endif
  assign product_id = shop.url | append: '/#product-kevin'
  assign price_valid_until = 'now' | date: '%Y' | plus: 1 | append: '-12-31'
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": {{ org_id | json }},
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "logo": {{ org_logo | json }},
  "description": {{ org_description | json }},
  "email": {{ org_email | json }},
  "slogan": "Presence that prevents.",
  "knowsAbout": ["home security", "burglary prevention", "presence simulation", "Swiss engineering"],
  "areaServed": [
    { "@type": "Country", "name": "Switzerland" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "France" },
    { "@type": "Country", "name": "Ireland" },
    { "@type": "Country", "name": "Netherlands" },
    { "@type": "Country", "name": "Czech Republic" }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": {{ site_id | json }},
  "url": {{ shop.url | json }},
  "name": {{ shop.name | json }},
  "description": {{ org_description | json }},
  "publisher": { "@id": {{ org_id | json }} },
  "inLanguage": {{ request.locale.iso_code | json }}
}
</script>
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": {{ product_id | json }},
  "name": "KEVIN 3.0",
  "alternateName": "Kevin presence simulator",
  "category": "Home Security Presence Simulator",
  "description": {{ org_description | json }},
  "url": {{ product_url | json }},
  "sku": {{ product_sku | json }},
  "image": {{ kevin_image | json }},
  "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
  "manufacturer": { "@id": {{ org_id | json }} },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Power consumption", "value": "Approximately 9 W (typical)" },
    { "@type": "PropertyValue", "name": "Dimensions", "value": "Approx. 21.2 x 10.2 x 9.2 cm" },
    { "@type": "PropertyValue", "name": "Connectivity", "value": "Wi-Fi and Bluetooth" },
    { "@type": "PropertyValue", "name": "Cameras", "value": "None" },
    { "@type": "PropertyValue", "name": "Microphones", "value": "None" },
    { "@type": "PropertyValue", "name": "Simulation library", "value": "70+ hours, stored locally" },
    { "@type": "PropertyValue", "name": "Jammer resilient", "value": "Yes — simulations play from local storage" },
    { "@type": "PropertyValue", "name": "Warranty", "value": "3-year Swiss warranty" }
  ],
  "offers": {
    "@type": "Offer",
    "url": {{ product_url | json }},
    "priceCurrency": {{ offer_currency | json }},
    "price": {{ offer_price | json }},
    "priceValidUntil": {{ price_valid_until | json }},
    "availability": {{ offer_availability | json }},
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@id": {{ org_id | json }} },
    "warranty": {
      "@type": "WarrantyPromise",
      "durationOfWarranty": { "@type": "QuantitativeValue", "value": 3, "unitCode": "ANN" }
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": 0, "currency": {{ offer_currency | json }} },
      "shippingDestination": [
        { "@type": "DefinedRegion", "addressCountry": "CH" },
        { "@type": "DefinedRegion", "addressCountry": "DE" },
        { "@type": "DefinedRegion", "addressCountry": "FR" },
        { "@type": "DefinedRegion", "addressCountry": "IE" },
        { "@type": "DefinedRegion", "addressCountry": "NL" },
        { "@type": "DefinedRegion", "addressCountry": "CZ" }
      ]
    }
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": {{ shop.url | append: '/#webpage-home' | json }},
  "url": {{ shop.url | json }},
  "name": {{ 'seo.home.title' | t | json }},
  "description": {{ org_description | json }},
  "inLanguage": {{ request.locale.iso_code | json }},
  "isPartOf": { "@id": {{ site_id | json }} },
  "about": { "@id": {{ product_id | json }} },
  "primaryImageOfPage": {{ kevin_image | json }},
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["#HeroHeading", ".hero-banner__lede"]
  },
  "significantLink": [
    {{ 'kevin.md' | asset_url | prepend: 'https:' | json }},
    {{ 'kevin-product.md' | asset_url | prepend: 'https:' | json }},
    {{ 'kevin-specs.md' | asset_url | prepend: 'https:' | json }},
    {{ 'kevin-faq.md' | asset_url | prepend: 'https:' | json }},
    {{ 'kevin-company.md' | asset_url | prepend: 'https:' | json }},
    {{ 'llms.txt' | asset_url | prepend: 'https:' | json }},
    {{ 'llms-full.txt' | asset_url | prepend: 'https:' | json }}
  ]
}
</script>
{%- endif -%}
{%- if request.page_type == 'page' -%}
  {%- assign llm_page_handles = 'llms,ai-overzicht,apercu-ia,ki-uebersicht,resumen-ia,panoramica-ia,ai-oversikt,ai-oversigt,ai-yhteenveto,ai-prehled,podsumowanie-ai' | split: ',' -%}
  {%- if page.handle == 'sitemap' or llm_page_handles contains page.handle -%}
    {%- if page.handle == 'sitemap' -%}
      {%- assign web_page_description = 'seo.sitemap.description' | t -%}
    {%- else -%}
      {%- assign web_page_description = 'seo.llms.description' | t -%}
    {%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ page.title | default: shop.name | json }},
  "description": {{ web_page_description | default: org_description | json }},
  "url": {{ canonical_url | json }},
  "inLanguage": {{ request.locale.iso_code | json }},
  "isPartOf": { "@id": {{ site_id | json }} },
  "significantLink": [
    {{ 'llms.txt' | asset_url | prepend: 'https:' | json }},
    {{ 'llms-full.txt' | asset_url | prepend: 'https:' | json }},
    {{ 'kevin.md' | asset_url | prepend: 'https:' | json }},
    {{ 'sitemap-ai.xml' | asset_url | prepend: 'https:' | json }},
    {{ shop.url | append: '/sitemap.xml' | json }}
  ]
}
</script>
  {%- endif -%}
{%- endif -%}

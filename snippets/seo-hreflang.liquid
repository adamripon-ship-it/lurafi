{%- comment -%}
  hreflang alternates for published storefront languages.
  Pairs with canonical in layout/theme.liquid.
{%- endcomment -%}
{%- liquid
  assign path_suffix = request.path
  assign locale_root = request.locale.root_url
  if locale_root != '/' and path_suffix contains locale_root
    assign path_suffix = path_suffix | remove_first: locale_root
  endif
  if path_suffix == blank
    assign path_suffix = '/'
  endif
  unless path_suffix contains '/'
    assign path_suffix = '/' | append: path_suffix
  endunless

  assign x_default_href = request.origin | append: path_suffix
  assign published_hreflang_count = 0
  for language in localization.available_languages
    assign lang_root = language.iso_code | split: '-' | first | downcase
    unless lurafi_published_locale_codes contains lang_root
      continue
    endunless
    assign published_hreflang_count = published_hreflang_count | plus: 1
    if language.primary
      assign x_default_href = request.origin | append: language.root_url | append: path_suffix
    endif
  endfor
-%}
{%- if published_hreflang_count > 1 -%}
  {%- for language in localization.available_languages -%}
    {%- assign lang_root = language.iso_code | split: '-' | first | downcase -%}
    {%- unless lurafi_published_locale_codes contains lang_root -%}
      {%- continue -%}
    {%- endunless -%}
    {%- assign lang_href = request.origin | append: language.root_url | append: path_suffix -%}
    {%- if request.search != blank -%}
      {%- assign lang_href = lang_href | append: request.search -%}
    {%- endif -%}
    <link rel="alternate" hreflang="{{ language.iso_code }}" href="{{ lang_href }}">
  {%- endfor -%}
  {%- if request.search != blank -%}
    {%- assign x_default_href = x_default_href | append: request.search -%}
  {%- endif -%}
  <link rel="alternate" hreflang="x-default" href="{{ x_default_href }}">
{%- endif -%}
